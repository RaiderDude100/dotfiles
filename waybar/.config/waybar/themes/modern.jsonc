{
  "layer": "top", // Waybar at top layer
  "spacing": 4, // Gaps between modules (4px)
  "modules-left": [],
  "modules-center": [
    "group/main"
  ],
  "modules-right": [],
  "include": [
    "~/.config/waybar/modules.json"
  ],
  "hyprland/workspaces": {
    "persistent-workspaces": {
      "*": 1
    },
    "sort-by": "number",
    "all-outputs": true
  },
  "hyprland/window": {
    "format": "{title}",
    "icon": false,
    "icon-size": 13,
    "max-length": 20,
    "rewrite": {
      "(rofi - drun)": ""
    }
  },
  "tray": {
    "spacing": 4
  },
  "clock": {
    "interval": 60,
    "format": "{:%I:%M %p}",
    "format-alt": "{:%d/%m/%Y}",
    "tooltip-format": "{calendar}"
  },
  "network": {
    "format-wifi": "",
    "format-ethernet": "󰈀",
    "tooltip-format": "{ifname}/{essid} via {gwaddr}",
    "format-disconnected": "󰌙",
    "max-length": 12,
    "on-click": "kitty -e nmtui"
  },
  "pulseaudio": {
      "format": "{icon}",
      "format-bluetooth": "{icon}",
      "format-muted": "",
      "format-icons": {
          "headphone": "",
          "hands-free": "",
          "headset": "",
          "phone": "",
          "phone-muted": "",
          "portable": "",
          "car": "",
          "default": ["","", ""]
      },
      "scroll-step": 1,
      "on-click": "pavucontrol"
  },
  "battery": {
    "format": "{icon}",
    "format-charging": "󰂄",
    "format-plugged": "󰚥",
    "format-icons": [
      "󰂎",
      "󰁻",
      "󰁽",
      "󰁿",
      "󰂁",
      "󰁹"
    ]
  },
  "group/trays": {
    "orientation": "horizontal",
    "modules": [
      "clock",
      "tray"
    ]
  },
  "group/main": {
    "orientation": "horizontal",
    "modules": [
      "hyprland/workspaces",
      "custom/gap",
      "hyprland/window",
      "custom/gap",
      "clock",
      "custom/gap",
      "pulseaudio",
      "battery",
      "network",
      "tray",
      "custom/gap"
    ]
  }
}
