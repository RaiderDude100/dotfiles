{
  "layer": "top", // Waybar at top layer
  "spacing": 4, // Gaps between modules (4px)
  "modules-left": [],
  "modules-center": [
    "group/main"
  ],
  "modules-right": [],
  "include": [
    "~/.config/waybar/modules.json"
  ],
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
        "urgent": "ï„‘",
        "default": "ï„Œ",
        "active": "ï†’"
    },
    "persistent-workspaces": {
      "*": 0
    },
    "sort-by": "number",
    "separate-outputs": true
  },
  "hyprland/window": {
    "format": "{title}",
    "icon": false,
    "icon-size": 13,
    "max-length": 20,
    "rewrite": {
      "(rofi - drun)": ""
    }
  },
  "tray": {
    "spacing": 4
  },
  "clock": {
    "interval": 60,
    "format": "{:%I:%M %p}",
    "format-alt": "{:%d/%m/%Y}",
    "tooltip-format": "{calendar}"
  },
  "network": {
    "format-wifi": "ï‡«",
    "format-ethernet": "َ°ˆ€",
    "tooltip-format": "{ifname}/{essid} via {gwaddr}",
    "format-disconnected": "َ°Œ™",
    "max-length": 12,
    "on-click": "$(cat ~/.config/hypr/vars/terminal) -e nmtui"
  },
  "pulseaudio": {
      "format": "{icon}",
      "format-bluetooth": "{icon}َ°‚¯",
      "format-muted": "َ°‌ں",
      "format-icons": {
          "headphone": "َ°‹‹",
          "headphone-muted": "َ°ںژ",
          "hands-free": "ï–گ",
          "headset": "َ°‹ژ",
          "headset-muted": "َ°‹گ",
          "phone": "َ°ڈ²",
          "phone-muted": "َ°·¯",
          "portable": "َ°ڈ²",
          "car": "ï†¹",
          "default": ["َ°•؟","َ°–€", "َ°•¾"]
      },
      "scroll-step": 1,
      "on-click": "pavucontrol"
  },
  "battery": {
    "format": "{icon}",
    "format-charging": "َ°‚„",
    "format-plugged": "َ°ڑ¥",
    "format-icons": [
      "َ°‚ژ",
      "َ°پ»",
      "َ°پ½",
      "َ°پ؟",
      "َ°‚پ",
      "َ°پ¹"
    ]
  },
  "group/trays": {
    "orientation": "horizontal",
    "modules": [
      "clock",
      "tray"
    ]
  },
  "group/main": {
    "orientation": "horizontal",
    "modules": [
      "hyprland/workspaces",
      "custom/gap",
      "clock",
      "custom/gap",
      "pulseaudio",
      "battery",
      "network",
      "tray",
      "custom/gap"
    ]
  }
}
