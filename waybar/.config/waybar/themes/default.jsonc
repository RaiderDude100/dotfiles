{
  "layer": "top", // Waybar at top layer
  "spacing": 1, // Gaps between modules (4px)
  "modules-left": [
    "group/menus",
    "hyprland/workspaces",
    "custom/updates"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "pulseaudio",
    "battery",
    "network",
    "group/trays"
  ],
  "include": [
    "~/.config/waybar/modules.json"
  ],
  "hyprland/workspaces": {
    "persistent-workspaces": {
      "*": 5
    },
    "sort-by": "number",
    "separate-outputs": true
  },
  "hyprland/window": {
    "format": "{title}",
    "icon": true,
    "icon-size": 13,
    "max-length": 32,
    "rewrite": {
      "(rofi - drun)": ""
    }
  },
  "tray": {
    "spacing": 4
  },
  "clock": {
    "interval": 60,
    "format": "{:%I:%M %p}",
    "format-alt": "{:%d/%m/%Y}",
    "tooltip-format": "{calendar}"
  },
  "network": {
    "format-wifi": " {essid}",
    "format-ethernet": "󰈀 Ethernet",
    "tooltip-format": "{ifname}/{essid} via {gwaddr}",
    "format-disconnected": "󰌙 Disconnected",
    "max-length": 12,
    "on-click": "$(cat ~/.config/hypr/vars/terminal) -e nmtui"
  },
  "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-bluetooth": "{icon}󰂯 {volume}%",
      "format-muted": "󰝟",
      "format-icons": {
          "headphone": "󰋋",
          "headphone-muted": "󰟎",
          "hands-free": "",
          "headset": "󰋎",
          "headset-muted": "󰋐",
          "phone": "󰏲",
          "phone-muted": "󰷯",
          "portable": "󰏲",
          "car": "",
          "default": ["󰕿","󰖀", "󰕾"]
      },
      "scroll-step": 1,
      "on-click": "pavucontrol"
  },
  "group/trays": {
    "orientation": "horizontal",
    "modules": [
      "clock",
      "tray"
    ]
  },
  "group/menus": {
    "orientation": "horizontal",
    "modules": [
      "custom/powermenu",
      "custom/gap",
      "custom/launcher"
    ]
  }
}
