# Position
anchor=top-right

# Size
width=400
height=150

# Margin
margin=10

# Padding
padding=10

# Border
border-size=0
border-radius=15

# Font
font=Space Mono Nerd Font 13.7

# Timeout
default-timeout=5000

# Icons
icons=1

# Max visible notifications
max-visible=5

# Notification history
max-history=100
history=1

include=~/.config/mako/mako-colors
