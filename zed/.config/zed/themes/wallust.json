{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#151914",
                "text": "#BCD1F9",
                "text.muted": "#96A7C7",
                "text.placeholder": "#8492AE",
                "text.disabled": "#717D95",
                "text.accent": "#4A7BBD",

                // Icon colors - match text hierarchy
                "icon": "#BCD1F9",
                "icon.muted": "#96A7C7",
                "icon.disabled": "#717D95",
                "icon.placeholder": "#8492AE",
                "icon.accent": "#4A7BBD",

                // Border colors - subtle but visible
                "border": "#4B5464",
                "border.variant": "#383F4B",
                "border.focused": "#4A7BBD",
                "border.selected": "#4A7BBD",
                "border.transparent": "#00000000",
                "border.disabled": "#262A32",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#151914",
                "elevated_surface.background": "#2C302C",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#2A2F36",
                "element.active": "#1D2C3E",
                "element.selected": "#182534",
                "element.disabled": "#212420",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#15171B",
                "ghost_element.active": "#2A2F36",
                "ghost_element.selected": "#0E161F",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#223449",

                // Application frame elements
                "status_bar.background": "#212420",
                "title_bar.background": "#151914",
                "title_bar.inactive_background": "#1C201B",
                "toolbar.background": "#151914",

                // Side panels
                "panel.background": "#151914",
                "panel.focused_border": "#4A7BBD",

                // Editor panes
                "pane.focused_border": "#4A7BBD",
                "pane_group.border": "#4B5464",

                // Tab bar and tabs
                "tab_bar.background": "#212420",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#151914",

                // Main editor area
                "editor.background": "#151914",
                "editor.foreground": "#BCD1F9",
                "editor.gutter.background": "#151914",
                "editor.subheader.background": "#212420",
                "editor.active_line.background": "#15171B",
                "editor.highlighted_line.background": "#141E25",
                "editor.line_number": "#717D95",
                "editor.active_line_number": "#BCD1F9",
                "editor.invisible": "#5E697D",
                "editor.wrap_guide": "#4B5464",
                "editor.active_wrap_guide": "#717D95",
                "editor.indent_guide": "#4B5464",
                "editor.indent_guide_active": "#717D95",
                "editor.document_highlight.read_background": "#19252E",
                "editor.document_highlight.write_background": "#1C2521",
                "editor.document_highlight.bracket_background": "#182534",

                // Integrated terminal
                "terminal.background": "#151914",
                "terminal.foreground": "#BCD1F9",
                "terminal.bright_foreground": "#C3D6FA",
                "terminal.dim_foreground": "#96A7C7",
                "terminal.ansi.background": "#151914",
                "terminal.ansi.black": "#292E28",
                "terminal.ansi.red": "#597A71",
                "terminal.ansi.green": "#547A8A",
                "terminal.ansi.yellow": "#4F7AA4",
                "terminal.ansi.blue": "#4A7BBD",
                "terminal.ansi.magenta": "#457BD6",
                "terminal.ansi.cyan": "#407BEF",
                "terminal.ansi.white": "#97B5EF",
                "terminal.ansi.bright_black": "#6A7EA7",
                "terminal.ansi.bright_red": "#597A71",
                "terminal.ansi.bright_green": "#547A8A",
                "terminal.ansi.bright_yellow": "#4F7AA4",
                "terminal.ansi.bright_blue": "#4A7BBD",
                "terminal.ansi.bright_magenta": "#457BD6",
                "terminal.ansi.bright_cyan": "#407BEF",
                "terminal.ansi.bright_white": "#97B5EF",

                // Search functionality
                "search.match_background": "#283B4A",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#5E697D",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#8492AE",

                // Status indicators - success, warning, error, info
                "success": "#547A8A",
                "success.background": "#1A2528",
                "success.border": "#547A8A",

                "warning": "#4F7AA4",
                "warning.background": "#19252E",
                "warning.border": "#4F7AA4",

                "error": "#597A71",
                "error.background": "#1C2521",
                "error.border": "#597A71",

                "info": "#4A7BBD",
                "info.background": "#182534",
                "info.border": "#4A7BBD",

                "hint": "#96A7C7",
                "hint.background": "#1F2329",
                "hint.border": "#96A7C7",

                // Git status colors
                "created": "#547A8A",
                "created.background": "#1A2528",
                "created.border": "#547A8A",

                "modified": "#4F7AA4",
                "modified.background": "#19252E",
                "modified.border": "#4F7AA4",

                "deleted": "#597A71",
                "deleted.background": "#1C2521",
                "deleted.border": "#597A71",

                "renamed": "#4A7BBD",
                "renamed.background": "#182534",
                "renamed.border": "#4A7BBD",

                "conflict": "#457BD6",
                "conflict.background": "#16253B",
                "conflict.border": "#457BD6",

                "ignored": "#8492AE",
                "ignored.background": "#15171B",
                "ignored.border": "#8492AE",

                "hidden": "#717D95",
                "hidden.background": "transparent",
                "hidden.border": "#717D95",

                "predictive": "#8492AE",
                "predictive.background": "#15171B",
                "predictive.border": "#8492AE",

                "unreachable": "#5E697D",
                "unreachable.background": "#1C201B",
                "unreachable.border": "#5E697D",

                // Link styling
                "link_text.hover": "#5C88C4",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#96A7C7",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#A9BCE0",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#597A71"
                    },

                    // Strings
                    "string": {
                        "color": "#547A8A"
                    },
                    "string.escape": {
                        "color": "#407BEF"
                    },
                    "string.regex": {
                        "color": "#407BEF"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#4F7AA4"
                    },
                    "constant": {
                        "color": "#4F7AA4"
                    },
                    "boolean": {
                        "color": "#457BD6"
                    },

                    // Functions
                    "function": {
                        "color": "#4A7BBD"
                    },
                    "constructor": {
                        "color": "#4A7BBD"
                    },

                    // Types
                    "type": {
                        "color": "#457BD6"
                    },
                    "enum": {
                        "color": "#457BD6"
                    },

                    // Variables
                    "variable": {
                        "color": "#BCD1F9"
                    },
                    "variable.special": {
                        "color": "#457BD6"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#4A7BBD"
                    },
                    "attribute": {
                        "color": "#4F7AA4"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#407BEF"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#A9BCE0"
                    },
                    "punctuation.bracket": {
                        "color": "#BCD1F9"
                    },
                    "punctuation.delimiter": {
                        "color": "#A9BCE0"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#597A71"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#4A7BBD"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#547A8A"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#4A7BBD",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#4A7BBD",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#407BEF"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#BCD1F9"
                    },
                    "preproc": {
                        "color": "#597A71"
                    },
                    "primary": {
                        "color": "#BCD1F9"
                    },
                    "variant": {
                        "color": "#457BD6"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#96A7C7",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#8492AE",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#4A7BBD",
                        "background": "#4A7BBD",
                        "selection": "#223449"
                    },
                    {
                        "cursor": "#547A8A",
                        "background": "#547A8A",
                        "selection": "#243437"
                    },
                    {
                        "cursor": "#4F7AA4",
                        "background": "#4F7AA4",
                        "selection": "#233440"
                    },
                    {
                        "cursor": "#457BD6",
                        "background": "#457BD6",
                        "selection": "#203452"
                    }
                ]
            }
        }
    ]
}
