{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#0C1018",
                "text": "#CDE9EA",
                "text.muted": "#A4BABB",
                "text.placeholder": "#90A3A4",
                "text.disabled": "#7B8C8C",
                "text.accent": "#2BA19B",

                // Icon colors - match text hierarchy
                "icon": "#CDE9EA",
                "icon.muted": "#A4BABB",
                "icon.disabled": "#7B8C8C",
                "icon.placeholder": "#90A3A4",
                "icon.accent": "#2BA19B",

                // Border colors - subtle but visible
                "border": "#525D5E",
                "border.variant": "#3E4646",
                "border.focused": "#2BA19B",
                "border.selected": "#2BA19B",
                "border.transparent": "#00000000",
                "border.disabled": "#292F2F",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#0C1018",
                "elevated_surface.background": "#24282F",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#2C3234",
                "element.active": "#113536",
                "element.selected": "#0E2C2D",
                "element.disabled": "#181C24",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#16191A",
                "ghost_element.active": "#2C3234",
                "ghost_element.selected": "#081A1B",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#143E3F",

                // Application frame elements
                "status_bar.background": "#181C24",
                "title_bar.background": "#0C1018",
                "title_bar.inactive_background": "#13171F",
                "toolbar.background": "#0C1018",

                // Side panels
                "panel.background": "#0C1018",
                "panel.focused_border": "#2BA19B",

                // Editor panes
                "pane.focused_border": "#2BA19B",
                "pane_group.border": "#525D5E",

                // Tab bar and tabs
                "tab_bar.background": "#181C24",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#0C1018",

                // Main editor area
                "editor.background": "#0C1018",
                "editor.foreground": "#CDE9EA",
                "editor.gutter.background": "#0C1018",
                "editor.subheader.background": "#181C24",
                "editor.active_line.background": "#16191A",
                "editor.highlighted_line.background": "#0E1F22",
                "editor.line_number": "#7B8C8C",
                "editor.active_line_number": "#CDE9EA",
                "editor.invisible": "#677575",
                "editor.wrap_guide": "#525D5E",
                "editor.active_wrap_guide": "#7B8C8C",
                "editor.indent_guide": "#525D5E",
                "editor.indent_guide_active": "#7B8C8C",
                "editor.document_highlight.read_background": "#11272A",
                "editor.document_highlight.write_background": "#162025",
                "editor.document_highlight.bracket_background": "#0E2C2D",

                // Integrated terminal
                "terminal.background": "#0C1018",
                "terminal.foreground": "#CDE9EA",
                "terminal.bright_foreground": "#D2EBEC",
                "terminal.dim_foreground": "#A4BABB",
                "terminal.ansi.background": "#0C1018",
                "terminal.ansi.black": "#0F131C",
                "terminal.ansi.red": "#4E727B",
                "terminal.ansi.green": "#548790",
                "terminal.ansi.yellow": "#398D92",
                "terminal.ansi.blue": "#2BA19B",
                "terminal.ansi.magenta": "#83B2BB",
                "terminal.ansi.cyan": "#6CBFBF",
                "terminal.ansi.white": "#CDE9EA",
                "terminal.ansi.bright_black": "#232831",
                "terminal.ansi.bright_red": "#4E727B",
                "terminal.ansi.bright_green": "#548790",
                "terminal.ansi.bright_yellow": "#398D92",
                "terminal.ansi.bright_blue": "#2BA19B",
                "terminal.ansi.bright_magenta": "#83B2BB",
                "terminal.ansi.bright_cyan": "#6CBFBF",
                "terminal.ansi.bright_white": "#CDE9EA",

                // Search functionality
                "search.match_background": "#1B3E44",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#677575",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#90A3A4",

                // Status indicators - success, warning, error, info
                "success": "#548790",
                "success.background": "#18262A",
                "success.border": "#548790",

                "warning": "#398D92",
                "warning.background": "#11272A",
                "warning.border": "#398D92",

                "error": "#4E727B",
                "error.background": "#162025",
                "error.border": "#4E727B",

                "info": "#2BA19B",
                "info.background": "#0E2C2D",
                "info.border": "#2BA19B",

                "hint": "#A4BABB",
                "hint.background": "#212627",
                "hint.border": "#A4BABB",

                // Git status colors
                "created": "#548790",
                "created.background": "#18262A",
                "created.border": "#548790",

                "modified": "#398D92",
                "modified.background": "#11272A",
                "modified.border": "#398D92",

                "deleted": "#4E727B",
                "deleted.background": "#162025",
                "deleted.border": "#4E727B",

                "renamed": "#2BA19B",
                "renamed.background": "#0E2C2D",
                "renamed.border": "#2BA19B",

                "conflict": "#83B2BB",
                "conflict.background": "#243135",
                "conflict.border": "#83B2BB",

                "ignored": "#90A3A4",
                "ignored.background": "#16191A",
                "ignored.border": "#90A3A4",

                "hidden": "#7B8C8C",
                "hidden.background": "transparent",
                "hidden.border": "#7B8C8C",

                "predictive": "#90A3A4",
                "predictive.background": "#16191A",
                "predictive.border": "#90A3A4",

                "unreachable": "#677575",
                "unreachable.background": "#13171F",
                "unreachable.border": "#677575",

                // Link styling
                "link_text.hover": "#40AAA5",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#A4BABB",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#B9D2D3",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#4E727B"
                    },

                    // Strings
                    "string": {
                        "color": "#548790"
                    },
                    "string.escape": {
                        "color": "#6CBFBF"
                    },
                    "string.regex": {
                        "color": "#6CBFBF"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#398D92"
                    },
                    "constant": {
                        "color": "#398D92"
                    },
                    "boolean": {
                        "color": "#83B2BB"
                    },

                    // Functions
                    "function": {
                        "color": "#2BA19B"
                    },
                    "constructor": {
                        "color": "#2BA19B"
                    },

                    // Types
                    "type": {
                        "color": "#83B2BB"
                    },
                    "enum": {
                        "color": "#83B2BB"
                    },

                    // Variables
                    "variable": {
                        "color": "#CDE9EA"
                    },
                    "variable.special": {
                        "color": "#83B2BB"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#2BA19B"
                    },
                    "attribute": {
                        "color": "#398D92"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#6CBFBF"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#B9D2D3"
                    },
                    "punctuation.bracket": {
                        "color": "#CDE9EA"
                    },
                    "punctuation.delimiter": {
                        "color": "#B9D2D3"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#4E727B"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#2BA19B"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#548790"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#2BA19B",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#2BA19B",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#6CBFBF"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#CDE9EA"
                    },
                    "preproc": {
                        "color": "#4E727B"
                    },
                    "primary": {
                        "color": "#CDE9EA"
                    },
                    "variant": {
                        "color": "#83B2BB"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#A4BABB",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#90A3A4",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#2BA19B",
                        "background": "#2BA19B",
                        "selection": "#143E3F"
                    },
                    {
                        "cursor": "#548790",
                        "background": "#548790",
                        "selection": "#22353B"
                    },
                    {
                        "cursor": "#398D92",
                        "background": "#398D92",
                        "selection": "#18373C"
                    },
                    {
                        "cursor": "#83B2BB",
                        "background": "#83B2BB",
                        "selection": "#32444A"
                    }
                ]
            }
        }
    ]
}
