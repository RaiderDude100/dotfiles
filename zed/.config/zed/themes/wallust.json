{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#0C1110",
                "text": "#CBD1D0",
                "text.muted": "#A2A7A6",
                "text.placeholder": "#8E9292",
                "text.disabled": "#7A7D7D",
                "text.accent": "#4882BA",

                // Icon colors - match text hierarchy
                "icon": "#CBD1D0",
                "icon.muted": "#A2A7A6",
                "icon.disabled": "#7A7D7D",
                "icon.placeholder": "#8E9292",
                "icon.accent": "#4882BA",

                // Border colors - subtle but visible
                "border": "#515453",
                "border.variant": "#3D3F3E",
                "border.focused": "#4882BA",
                "border.selected": "#4882BA",
                "border.transparent": "#00000000",
                "border.disabled": "#292A2A",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#0C1110",
                "elevated_surface.background": "#242928",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#2B2D2D",
                "element.active": "#192C3D",
                "element.selected": "#152533",
                "element.disabled": "#181D1C",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#161716",
                "ghost_element.active": "#2B2D2D",
                "ghost_element.selected": "#0D161E",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#1D3447",

                // Application frame elements
                "status_bar.background": "#181D1C",
                "title_bar.background": "#0C1110",
                "title_bar.inactive_background": "#131817",
                "toolbar.background": "#0C1110",

                // Side panels
                "panel.background": "#0C1110",
                "panel.focused_border": "#4882BA",

                // Editor panes
                "pane.focused_border": "#4882BA",
                "pane_group.border": "#515453",

                // Tab bar and tabs
                "tab_bar.background": "#181D1C",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#0C1110",

                // Main editor area
                "editor.background": "#0C1110",
                "editor.foreground": "#CBD1D0",
                "editor.gutter.background": "#0C1110",
                "editor.subheader.background": "#181D1C",
                "editor.active_line.background": "#161716",
                "editor.highlighted_line.background": "#181E1E",
                "editor.line_number": "#7A7D7D",
                "editor.active_line_number": "#CBD1D0",
                "editor.invisible": "#666968",
                "editor.wrap_guide": "#515453",
                "editor.active_wrap_guide": "#7A7D7D",
                "editor.indent_guide": "#515453",
                "editor.indent_guide_active": "#7A7D7D",
                "editor.document_highlight.read_background": "#1E2626",
                "editor.document_highlight.write_background": "#131C1F",
                "editor.document_highlight.bracket_background": "#152533",

                // Integrated terminal
                "terminal.background": "#0C1110",
                "terminal.foreground": "#CBD1D0",
                "terminal.bright_foreground": "#D0D6D5",
                "terminal.dim_foreground": "#A2A7A6",
                "terminal.ansi.background": "#0C1110",
                "terminal.ansi.black": "#0E1412",
                "terminal.ansi.red": "#405E6A",
                "terminal.ansi.green": "#677359",
                "terminal.ansi.yellow": "#6C8688",
                "terminal.ansi.blue": "#4882BA",
                "terminal.ansi.magenta": "#6A8F66",
                "terminal.ansi.cyan": "#93A84A",
                "terminal.ansi.white": "#CBD1D0",
                "terminal.ansi.bright_black": "#232827",
                "terminal.ansi.bright_red": "#405E6A",
                "terminal.ansi.bright_green": "#677359",
                "terminal.ansi.bright_yellow": "#6C8688",
                "terminal.ansi.bright_blue": "#4882BA",
                "terminal.ansi.bright_magenta": "#6A8F66",
                "terminal.ansi.bright_cyan": "#93A84A",
                "terminal.ansi.bright_white": "#CBD1D0",

                // Search functionality
                "search.match_background": "#303D3D",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#666968",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#8E9292",

                // Status indicators - success, warning, error, info
                "success": "#677359",
                "success.background": "#1D211A",
                "success.border": "#677359",

                "warning": "#6C8688",
                "warning.background": "#1E2626",
                "warning.border": "#6C8688",

                "error": "#405E6A",
                "error.background": "#131C1F",
                "error.border": "#405E6A",

                "info": "#4882BA",
                "info.background": "#152533",
                "info.border": "#4882BA",

                "hint": "#A2A7A6",
                "hint.background": "#202222",
                "hint.border": "#A2A7A6",

                // Git status colors
                "created": "#677359",
                "created.background": "#1D211A",
                "created.border": "#677359",

                "modified": "#6C8688",
                "modified.background": "#1E2626",
                "modified.border": "#6C8688",

                "deleted": "#405E6A",
                "deleted.background": "#131C1F",
                "deleted.border": "#405E6A",

                "renamed": "#4882BA",
                "renamed.background": "#152533",
                "renamed.border": "#4882BA",

                "conflict": "#6A8F66",
                "conflict.background": "#1E281E",
                "conflict.border": "#6A8F66",

                "ignored": "#8E9292",
                "ignored.background": "#161716",
                "ignored.border": "#8E9292",

                "hidden": "#7A7D7D",
                "hidden.background": "transparent",
                "hidden.border": "#7A7D7D",

                "predictive": "#8E9292",
                "predictive.background": "#161716",
                "predictive.border": "#8E9292",

                "unreachable": "#666968",
                "unreachable.background": "#131817",
                "unreachable.border": "#666968",

                // Link styling
                "link_text.hover": "#5A8FC1",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#A2A7A6",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#B7BCBB",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#405E6A"
                    },

                    // Strings
                    "string": {
                        "color": "#677359"
                    },
                    "string.escape": {
                        "color": "#93A84A"
                    },
                    "string.regex": {
                        "color": "#93A84A"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#6C8688"
                    },
                    "constant": {
                        "color": "#6C8688"
                    },
                    "boolean": {
                        "color": "#6A8F66"
                    },

                    // Functions
                    "function": {
                        "color": "#4882BA"
                    },
                    "constructor": {
                        "color": "#4882BA"
                    },

                    // Types
                    "type": {
                        "color": "#6A8F66"
                    },
                    "enum": {
                        "color": "#6A8F66"
                    },

                    // Variables
                    "variable": {
                        "color": "#CBD1D0"
                    },
                    "variable.special": {
                        "color": "#6A8F66"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#4882BA"
                    },
                    "attribute": {
                        "color": "#6C8688"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#93A84A"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#B7BCBB"
                    },
                    "punctuation.bracket": {
                        "color": "#CBD1D0"
                    },
                    "punctuation.delimiter": {
                        "color": "#B7BCBB"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#405E6A"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#4882BA"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#677359"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#4882BA",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#4882BA",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#93A84A"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#CBD1D0"
                    },
                    "preproc": {
                        "color": "#405E6A"
                    },
                    "primary": {
                        "color": "#CBD1D0"
                    },
                    "variant": {
                        "color": "#6A8F66"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#A2A7A6",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#8E9292",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#4882BA",
                        "background": "#4882BA",
                        "selection": "#1D3447"
                    },
                    {
                        "cursor": "#677359",
                        "background": "#677359",
                        "selection": "#292E24"
                    },
                    {
                        "cursor": "#6C8688",
                        "background": "#6C8688",
                        "selection": "#2A3535"
                    },
                    {
                        "cursor": "#6A8F66",
                        "background": "#6A8F66",
                        "selection": "#293829"
                    }
                ]
            }
        }
    ]
}
