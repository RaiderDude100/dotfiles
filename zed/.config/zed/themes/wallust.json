{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#060506",
                "text": "#A9665C",
                "text.muted": "#87524A",
                "text.placeholder": "#764740",
                "text.disabled": "#653D37",
                "text.accent": "#837478",

                // Icon colors - match text hierarchy
                "icon": "#A9665C",
                "icon.muted": "#87524A",
                "icon.disabled": "#653D37",
                "icon.placeholder": "#764740",
                "icon.accent": "#837478",

                // Border colors - subtle but visible
                "border": "#442925",
                "border.variant": "#331F1C",
                "border.focused": "#837478",
                "border.selected": "#837478",
                "border.transparent": "#00000000",
                "border.disabled": "#221412",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#060506",
                "elevated_surface.background": "#1F1E1F",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#231614",
                "element.active": "#292526",
                "element.selected": "#221F20",
                "element.disabled": "#121212",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#120B0A",
                "ghost_element.active": "#231614",
                "ghost_element.selected": "#141213",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#302B2C",

                // Application frame elements
                "status_bar.background": "#121212",
                "title_bar.background": "#060506",
                "title_bar.inactive_background": "#0D0C0D",
                "toolbar.background": "#060506",

                // Side panels
                "panel.background": "#060506",
                "panel.focused_border": "#837478",

                // Editor panes
                "pane.focused_border": "#837478",
                "pane_group.border": "#442925",

                // Tab bar and tabs
                "tab_bar.background": "#121212",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#060506",

                // Main editor area
                "editor.background": "#060506",
                "editor.foreground": "#A9665C",
                "editor.gutter.background": "#060506",
                "editor.subheader.background": "#121212",
                "editor.active_line.background": "#120B0A",
                "editor.highlighted_line.background": "#171616",
                "editor.line_number": "#653D37",
                "editor.active_line_number": "#A9665C",
                "editor.invisible": "#54332E",
                "editor.wrap_guide": "#442925",
                "editor.active_wrap_guide": "#653D37",
                "editor.indent_guide": "#442925",
                "editor.indent_guide_active": "#653D37",
                "editor.document_highlight.read_background": "#1D1B1C",
                "editor.document_highlight.write_background": "#111111",
                "editor.document_highlight.bracket_background": "#221F20",

                // Integrated terminal
                "terminal.background": "#060506",
                "terminal.foreground": "#A9665C",
                "terminal.bright_foreground": "#B2756C",
                "terminal.dim_foreground": "#87524A",
                "terminal.ansi.background": "#060506",
                "terminal.ansi.black": "#070607",
                "terminal.ansi.red": "#3F3F3F",
                "terminal.ansi.green": "#56585D",
                "terminal.ansi.yellow": "#6B6669",
                "terminal.ansi.blue": "#837478",
                "terminal.ansi.magenta": "#996F69",
                "terminal.ansi.cyan": "#8F7473",
                "terminal.ansi.white": "#9A4B3F",
                "terminal.ansi.bright_black": "#1F1F1F",
                "terminal.ansi.bright_red": "#3F3F3F",
                "terminal.ansi.bright_green": "#56585D",
                "terminal.ansi.bright_yellow": "#6B6669",
                "terminal.ansi.bright_blue": "#837478",
                "terminal.ansi.bright_magenta": "#996F69",
                "terminal.ansi.bright_cyan": "#8F7473",
                "terminal.ansi.bright_white": "#9A4B3F",

                // Search functionality
                "search.match_background": "#2E2B2D",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#54332E",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#764740",

                // Status indicators - success, warning, error, info
                "success": "#56585D",
                "success.background": "#171719",
                "success.border": "#56585D",

                "warning": "#6B6669",
                "warning.background": "#1D1B1C",
                "warning.border": "#6B6669",

                "error": "#3F3F3F",
                "error.background": "#111111",
                "error.border": "#3F3F3F",

                "info": "#837478",
                "info.background": "#221F20",
                "info.border": "#837478",

                "hint": "#87524A",
                "hint.background": "#1A100F",
                "hint.border": "#87524A",

                // Git status colors
                "created": "#56585D",
                "created.background": "#171719",
                "created.border": "#56585D",

                "modified": "#6B6669",
                "modified.background": "#1D1B1C",
                "modified.border": "#6B6669",

                "deleted": "#3F3F3F",
                "deleted.background": "#111111",
                "deleted.border": "#3F3F3F",

                "renamed": "#837478",
                "renamed.background": "#221F20",
                "renamed.border": "#837478",

                "conflict": "#996F69",
                "conflict.background": "#281D1C",
                "conflict.border": "#996F69",

                "ignored": "#764740",
                "ignored.background": "#120B0A",
                "ignored.border": "#764740",

                "hidden": "#653D37",
                "hidden.background": "transparent",
                "hidden.border": "#653D37",

                "predictive": "#764740",
                "predictive.background": "#120B0A",
                "predictive.border": "#764740",

                "unreachable": "#54332E",
                "unreachable.background": "#0D0C0D",
                "unreachable.border": "#54332E",

                // Link styling
                "link_text.hover": "#8F8286",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#87524A",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#985C53",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#3F3F3F"
                    },

                    // Strings
                    "string": {
                        "color": "#56585D"
                    },
                    "string.escape": {
                        "color": "#8F7473"
                    },
                    "string.regex": {
                        "color": "#8F7473"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#6B6669"
                    },
                    "constant": {
                        "color": "#6B6669"
                    },
                    "boolean": {
                        "color": "#996F69"
                    },

                    // Functions
                    "function": {
                        "color": "#837478"
                    },
                    "constructor": {
                        "color": "#837478"
                    },

                    // Types
                    "type": {
                        "color": "#996F69"
                    },
                    "enum": {
                        "color": "#996F69"
                    },

                    // Variables
                    "variable": {
                        "color": "#A9665C"
                    },
                    "variable.special": {
                        "color": "#996F69"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#837478"
                    },
                    "attribute": {
                        "color": "#6B6669"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#8F7473"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#985C53"
                    },
                    "punctuation.bracket": {
                        "color": "#A9665C"
                    },
                    "punctuation.delimiter": {
                        "color": "#985C53"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#3F3F3F"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#837478"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#56585D"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#837478",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#837478",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#8F7473"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#A9665C"
                    },
                    "preproc": {
                        "color": "#3F3F3F"
                    },
                    "primary": {
                        "color": "#A9665C"
                    },
                    "variant": {
                        "color": "#996F69"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#87524A",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#764740",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#837478",
                        "background": "#837478",
                        "selection": "#302B2C"
                    },
                    {
                        "cursor": "#56585D",
                        "background": "#56585D",
                        "selection": "#202023"
                    },
                    {
                        "cursor": "#6B6669",
                        "background": "#6B6669",
                        "selection": "#282627"
                    },
                    {
                        "cursor": "#996F69",
                        "background": "#996F69",
                        "selection": "#382927"
                    }
                ]
            }
        }
    ]
}
