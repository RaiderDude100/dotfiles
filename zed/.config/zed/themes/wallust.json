{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#FFFDFF",
                "text": "#110B1D",
                "text.muted": "#0E0917",
                "text.placeholder": "#0C0814",
                "text.disabled": "#0A0711",
                "text.accent": "#7353DA",

                // Icon colors - match text hierarchy
                "icon": "#110B1D",
                "icon.muted": "#0E0917",
                "icon.disabled": "#0A0711",
                "icon.placeholder": "#0C0814",
                "icon.accent": "#7353DA",

                // Border colors - subtle but visible
                "border": "#07040C",
                "border.variant": "#050309",
                "border.focused": "#7353DA",
                "border.selected": "#7353DA",
                "border.transparent": "#00000000",
                "border.disabled": "#030206",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#FFFDFF",
                "elevated_surface.background": "#FFFDFF",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#363539",
                "element.active": "#6F658E",
                "element.selected": "#5C5477",
                "element.disabled": "#FFFDFF",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#1B1A1C",
                "ghost_element.active": "#363539",
                "ghost_element.selected": "#383247",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#8276A6",

                // Application frame elements
                "status_bar.background": "#FFFDFF",
                "title_bar.background": "#FFFDFF",
                "title_bar.inactive_background": "#FFFDFF",
                "toolbar.background": "#FFFDFF",

                // Side panels
                "panel.background": "#FFFDFF",
                "panel.focused_border": "#7353DA",

                // Editor panes
                "pane.focused_border": "#7353DA",
                "pane_group.border": "#07040C",

                // Tab bar and tabs
                "tab_bar.background": "#FFFDFF",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#FFFDFF",

                // Main editor area
                "editor.background": "#FFFDFF",
                "editor.foreground": "#110B1D",
                "editor.gutter.background": "#FFFDFF",
                "editor.subheader.background": "#FFFDFF",
                "editor.active_line.background": "#1B1A1C",
                "editor.highlighted_line.background": "#4B4461",
                "editor.line_number": "#0A0711",
                "editor.active_line_number": "#110B1D",
                "editor.invisible": "#08060F",
                "editor.wrap_guide": "#07040C",
                "editor.active_wrap_guide": "#0A0711",
                "editor.indent_guide": "#07040C",
                "editor.indent_guide_active": "#0A0711",
                "editor.document_highlight.read_background": "#5E5579",
                "editor.document_highlight.write_background": "#6E6977",
                "editor.document_highlight.bracket_background": "#5C5477",

                // Integrated terminal
                "terminal.background": "#FFFDFF",
                "terminal.foreground": "#110B1D",
                "terminal.bright_foreground": "#292334",
                "terminal.dim_foreground": "#0E0917",
                "terminal.ansi.background": "#FFFDFF",
                "terminal.ansi.black": "#FFFDFF",
                "terminal.ansi.red": "#B8A4DA",
                "terminal.ansi.green": "#7E5DE5",
                "terminal.ansi.yellow": "#7857E4",
                "terminal.ansi.blue": "#7353DA",
                "terminal.ansi.magenta": "#261840",
                "terminal.ansi.cyan": "#261840",
                "terminal.ansi.white": "#110B1D",
                "terminal.ansi.bright_black": "#9285AB",
                "terminal.ansi.bright_red": "#B8A4DA",
                "terminal.ansi.bright_green": "#7E5DE5",
                "terminal.ansi.bright_yellow": "#7857E4",
                "terminal.ansi.bright_blue": "#7353DA",
                "terminal.ansi.bright_magenta": "#261840",
                "terminal.ansi.bright_cyan": "#261840",
                "terminal.ansi.bright_white": "#06040A",

                // Search functionality
                "search.match_background": "#9688C2",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#08060F",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#0C0814",

                // Status indicators - success, warning, error, info
                "success": "#7E5DE5",
                "success.background": "#605679",
                "success.border": "#7E5DE5",

                "warning": "#7857E4",
                "warning.background": "#5E5579",
                "warning.border": "#7857E4",

                "error": "#B8A4DA",
                "error.background": "#6E6977",
                "error.border": "#B8A4DA",

                "info": "#7353DA",
                "info.background": "#5C5477",
                "info.border": "#7353DA",

                "hint": "#0E0917",
                "hint.background": "#29282B",
                "hint.border": "#0E0917",

                // Git status colors
                "created": "#7E5DE5",
                "created.background": "#605679",
                "created.border": "#7E5DE5",

                "modified": "#7857E4",
                "modified.background": "#5E5579",
                "modified.border": "#7857E4",

                "deleted": "#B8A4DA",
                "deleted.background": "#6E6977",
                "deleted.border": "#B8A4DA",

                "renamed": "#7353DA",
                "renamed.background": "#5C5477",
                "renamed.border": "#7353DA",

                "conflict": "#261840",
                "conflict.background": "#494650",
                "conflict.border": "#261840",

                "ignored": "#0C0814",
                "ignored.background": "#1B1A1C",
                "ignored.border": "#0C0814",

                "hidden": "#0A0711",
                "hidden.background": "transparent",
                "hidden.border": "#0A0711",

                "predictive": "#0C0814",
                "predictive.background": "#1B1A1C",
                "predictive.border": "#0C0814",

                "unreachable": "#08060F",
                "unreachable.background": "#FFFDFF",
                "unreachable.border": "#08060F",

                // Link styling
                "link_text.hover": "#8164DE",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#0E0917",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#0F0A1A",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#B8A4DA"
                    },

                    // Strings
                    "string": {
                        "color": "#7E5DE5"
                    },
                    "string.escape": {
                        "color": "#261840"
                    },
                    "string.regex": {
                        "color": "#261840"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#7857E4"
                    },
                    "constant": {
                        "color": "#7857E4"
                    },
                    "boolean": {
                        "color": "#261840"
                    },

                    // Functions
                    "function": {
                        "color": "#7353DA"
                    },
                    "constructor": {
                        "color": "#7353DA"
                    },

                    // Types
                    "type": {
                        "color": "#261840"
                    },
                    "enum": {
                        "color": "#261840"
                    },

                    // Variables
                    "variable": {
                        "color": "#110B1D"
                    },
                    "variable.special": {
                        "color": "#261840"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#7353DA"
                    },
                    "attribute": {
                        "color": "#7857E4"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#261840"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#0F0A1A"
                    },
                    "punctuation.bracket": {
                        "color": "#110B1D"
                    },
                    "punctuation.delimiter": {
                        "color": "#0F0A1A"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#B8A4DA"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#7353DA"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#7E5DE5"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#7353DA",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#7353DA",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#261840"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#110B1D"
                    },
                    "preproc": {
                        "color": "#B8A4DA"
                    },
                    "primary": {
                        "color": "#110B1D"
                    },
                    "variant": {
                        "color": "#261840"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#0E0917",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#0C0814",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#7353DA",
                        "background": "#7353DA",
                        "selection": "#8276A6"
                    },
                    {
                        "cursor": "#7E5DE5",
                        "background": "#7E5DE5",
                        "selection": "#8679A9"
                    },
                    {
                        "cursor": "#7857E4",
                        "background": "#7857E4",
                        "selection": "#8477A9"
                    },
                    {
                        "cursor": "#261840",
                        "background": "#261840",
                        "selection": "#666170"
                    }
                ]
            }
        }
    ]
}
