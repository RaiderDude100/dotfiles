{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#1F191F",
                "text": "#D0B2D5",
                "text.muted": "#A68EAA",
                "text.placeholder": "#927D95",
                "text.disabled": "#7D6B80",
                "text.accent": "#7D7193",

                // Icon colors - match text hierarchy
                "icon": "#D0B2D5",
                "icon.muted": "#A68EAA",
                "icon.disabled": "#7D6B80",
                "icon.placeholder": "#927D95",
                "icon.accent": "#7D7193",

                // Border colors - subtle but visible
                "border": "#534755",
                "border.variant": "#3E3540",
                "border.focused": "#7D7193",
                "border.selected": "#7D7193",
                "border.transparent": "#00000000",
                "border.disabled": "#2A242B",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#1F191F",
                "elevated_surface.background": "#353035",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#302931",
                "element.active": "#2F2935",
                "element.selected": "#27222C",
                "element.disabled": "#2A242A",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#181418",
                "ghost_element.active": "#302931",
                "ghost_element.selected": "#17151B",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#37303E",

                // Application frame elements
                "status_bar.background": "#2A242A",
                "title_bar.background": "#1F191F",
                "title_bar.inactive_background": "#262026",
                "toolbar.background": "#1F191F",

                // Side panels
                "panel.background": "#1F191F",
                "panel.focused_border": "#7D7193",

                // Editor panes
                "pane.focused_border": "#7D7193",
                "pane_group.border": "#534755",

                // Tab bar and tabs
                "tab_bar.background": "#2A242A",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#1F191F",

                // Main editor area
                "editor.background": "#1F191F",
                "editor.foreground": "#D0B2D5",
                "editor.gutter.background": "#1F191F",
                "editor.subheader.background": "#2A242A",
                "editor.active_line.background": "#181418",
                "editor.highlighted_line.background": "#1B1921",
                "editor.line_number": "#7D6B80",
                "editor.active_line_number": "#D0B2D5",
                "editor.invisible": "#68596B",
                "editor.wrap_guide": "#534755",
                "editor.active_wrap_guide": "#7D6B80",
                "editor.indent_guide": "#534755",
                "editor.indent_guide_active": "#7D6B80",
                "editor.document_highlight.read_background": "#221F2A",
                "editor.document_highlight.write_background": "#241E21",
                "editor.document_highlight.bracket_background": "#27222C",

                // Integrated terminal
                "terminal.background": "#1F191F",
                "terminal.foreground": "#D0B2D5",
                "terminal.bright_foreground": "#D5BAD9",
                "terminal.dim_foreground": "#A68EAA",
                "terminal.ansi.background": "#1F191F",
                "terminal.ansi.black": "#241D25",
                "terminal.ansi.red": "#6F5D64",
                "terminal.ansi.green": "#675E74",
                "terminal.ansi.yellow": "#696387",
                "terminal.ansi.blue": "#7D7193",
                "terminal.ansi.magenta": "#8981AD",
                "terminal.ansi.cyan": "#8A80AA",
                "terminal.ansi.white": "#D0B2D5",
                "terminal.ansi.bright_black": "#3A323B",
                "terminal.ansi.bright_red": "#6F5D64",
                "terminal.ansi.bright_green": "#675E74",
                "terminal.ansi.bright_yellow": "#696387",
                "terminal.ansi.bright_blue": "#7D7193",
                "terminal.ansi.bright_magenta": "#8981AD",
                "terminal.ansi.bright_cyan": "#8A80AA",
                "terminal.ansi.bright_white": "#D0B2D5",

                // Search functionality
                "search.match_background": "#363242",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#68596B",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#927D95",

                // Status indicators - success, warning, error, info
                "success": "#675E74",
                "success.background": "#221E25",
                "success.border": "#675E74",

                "warning": "#696387",
                "warning.background": "#221F2A",
                "warning.border": "#696387",

                "error": "#6F5D64",
                "error.background": "#241E21",
                "error.border": "#6F5D64",

                "info": "#7D7193",
                "info.background": "#27222C",
                "info.border": "#7D7193",

                "hint": "#A68EAA",
                "hint.background": "#241F25",
                "hint.border": "#A68EAA",

                // Git status colors
                "created": "#675E74",
                "created.background": "#221E25",
                "created.border": "#675E74",

                "modified": "#696387",
                "modified.background": "#221F2A",
                "modified.border": "#696387",

                "deleted": "#6F5D64",
                "deleted.background": "#241E21",
                "deleted.border": "#6F5D64",

                "renamed": "#7D7193",
                "renamed.background": "#27222C",
                "renamed.border": "#7D7193",

                "conflict": "#8981AD",
                "conflict.background": "#2A2633",
                "conflict.border": "#8981AD",

                "ignored": "#927D95",
                "ignored.background": "#181418",
                "ignored.border": "#927D95",

                "hidden": "#7D6B80",
                "hidden.background": "transparent",
                "hidden.border": "#7D6B80",

                "predictive": "#927D95",
                "predictive.background": "#181418",
                "predictive.border": "#927D95",

                "unreachable": "#68596B",
                "unreachable.background": "#262026",
                "unreachable.border": "#68596B",

                // Link styling
                "link_text.hover": "#8A7F9E",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#A68EAA",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#BBA0C0",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#6F5D64"
                    },

                    // Strings
                    "string": {
                        "color": "#675E74"
                    },
                    "string.escape": {
                        "color": "#8A80AA"
                    },
                    "string.regex": {
                        "color": "#8A80AA"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#696387"
                    },
                    "constant": {
                        "color": "#696387"
                    },
                    "boolean": {
                        "color": "#8981AD"
                    },

                    // Functions
                    "function": {
                        "color": "#7D7193"
                    },
                    "constructor": {
                        "color": "#7D7193"
                    },

                    // Types
                    "type": {
                        "color": "#8981AD"
                    },
                    "enum": {
                        "color": "#8981AD"
                    },

                    // Variables
                    "variable": {
                        "color": "#D0B2D5"
                    },
                    "variable.special": {
                        "color": "#8981AD"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#7D7193"
                    },
                    "attribute": {
                        "color": "#696387"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#8A80AA"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#BBA0C0"
                    },
                    "punctuation.bracket": {
                        "color": "#D0B2D5"
                    },
                    "punctuation.delimiter": {
                        "color": "#BBA0C0"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#6F5D64"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#7D7193"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#675E74"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#7D7193",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#7D7193",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#8A80AA"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#D0B2D5"
                    },
                    "preproc": {
                        "color": "#6F5D64"
                    },
                    "primary": {
                        "color": "#D0B2D5"
                    },
                    "variant": {
                        "color": "#8981AD"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#A68EAA",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#927D95",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#7D7193",
                        "background": "#7D7193",
                        "selection": "#37303E"
                    },
                    {
                        "cursor": "#675E74",
                        "background": "#675E74",
                        "selection": "#2F2A34"
                    },
                    {
                        "cursor": "#696387",
                        "background": "#696387",
                        "selection": "#302B3A"
                    },
                    {
                        "cursor": "#8981AD",
                        "background": "#8981AD",
                        "selection": "#3B3647"
                    }
                ]
            }
        }
    ]
}
