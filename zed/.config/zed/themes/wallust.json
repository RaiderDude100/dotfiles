{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#131311",
                "text": "#FFEADD",
                "text.muted": "#CCBBB1",
                "text.placeholder": "#B2A49B",
                "text.disabled": "#998C85",
                "text.accent": "#BE6D55",

                // Icon colors - match text hierarchy
                "icon": "#FFEADD",
                "icon.muted": "#CCBBB1",
                "icon.disabled": "#998C85",
                "icon.placeholder": "#B2A49B",
                "icon.accent": "#BE6D55",

                // Border colors - subtle but visible
                "border": "#665E58",
                "border.variant": "#4C4642",
                "border.focused": "#BE6D55",
                "border.selected": "#BE6D55",
                "border.transparent": "#00000000",
                "border.disabled": "#332F2C",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#131311",
                "elevated_surface.background": "#2B2B29",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#373330",
                "element.active": "#3E261F",
                "element.selected": "#34201A",
                "element.disabled": "#1F1F1D",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#1B1918",
                "ghost_element.active": "#373330",
                "ghost_element.selected": "#1F130F",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#492D24",

                // Application frame elements
                "status_bar.background": "#1F1F1D",
                "title_bar.background": "#131311",
                "title_bar.inactive_background": "#1A1A18",
                "toolbar.background": "#131311",

                // Side panels
                "panel.background": "#131311",
                "panel.focused_border": "#BE6D55",

                // Editor panes
                "pane.focused_border": "#BE6D55",
                "pane_group.border": "#665E58",

                // Tab bar and tabs
                "tab_bar.background": "#1F1F1D",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#131311",

                // Main editor area
                "editor.background": "#131311",
                "editor.foreground": "#FFEADD",
                "editor.gutter.background": "#131311",
                "editor.subheader.background": "#1F1F1D",
                "editor.active_line.background": "#1B1918",
                "editor.highlighted_line.background": "#1F161C",
                "editor.line_number": "#998C85",
                "editor.active_line_number": "#FFEADD",
                "editor.invisible": "#80756F",
                "editor.wrap_guide": "#665E58",
                "editor.active_wrap_guide": "#998C85",
                "editor.indent_guide": "#665E58",
                "editor.indent_guide_active": "#998C85",
                "editor.document_highlight.read_background": "#271B23",
                "editor.document_highlight.write_background": "#1E1611",
                "editor.document_highlight.bracket_background": "#34201A",

                // Integrated terminal
                "terminal.background": "#131311",
                "terminal.foreground": "#FFEADD",
                "terminal.bright_foreground": "#FFECE0",
                "terminal.dim_foreground": "#CCBBB1",
                "terminal.ansi.background": "#131311",
                "terminal.ansi.black": "#3B3B39",
                "terminal.ansi.red": "#634532",
                "terminal.ansi.green": "#505E49",
                "terminal.ansi.yellow": "#8A5A7A",
                "terminal.ansi.blue": "#BE6D55",
                "terminal.ansi.magenta": "#A8AB8B",
                "terminal.ansi.cyan": "#FFC49F",
                "terminal.ansi.white": "#F6D9C7",
                "terminal.ansi.bright_black": "#AD988B",
                "terminal.ansi.bright_red": "#634532",
                "terminal.ansi.bright_green": "#505E49",
                "terminal.ansi.bright_yellow": "#8A5A7A",
                "terminal.ansi.bright_blue": "#BE6D55",
                "terminal.ansi.bright_magenta": "#A8AB8B",
                "terminal.ansi.bright_cyan": "#FFC49F",
                "terminal.ansi.bright_white": "#F6D9C7",

                // Search functionality
                "search.match_background": "#3E2B38",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#80756F",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#B2A49B",

                // Status indicators - success, warning, error, info
                "success": "#505E49",
                "success.background": "#191C16",
                "success.border": "#505E49",

                "warning": "#8A5A7A",
                "warning.background": "#271B23",
                "warning.border": "#8A5A7A",

                "error": "#634532",
                "error.background": "#1E1611",
                "error.border": "#634532",

                "info": "#BE6D55",
                "info.background": "#34201A",
                "info.border": "#BE6D55",

                "hint": "#CCBBB1",
                "hint.background": "#292624",
                "hint.border": "#CCBBB1",

                // Git status colors
                "created": "#505E49",
                "created.background": "#191C16",
                "created.border": "#505E49",

                "modified": "#8A5A7A",
                "modified.background": "#271B23",
                "modified.border": "#8A5A7A",

                "deleted": "#634532",
                "deleted.background": "#1E1611",
                "deleted.border": "#634532",

                "renamed": "#BE6D55",
                "renamed.background": "#34201A",
                "renamed.border": "#BE6D55",

                "conflict": "#A8AB8B",
                "conflict.background": "#2F3027",
                "conflict.border": "#A8AB8B",

                "ignored": "#B2A49B",
                "ignored.background": "#1B1918",
                "ignored.border": "#B2A49B",

                "hidden": "#998C85",
                "hidden.background": "transparent",
                "hidden.border": "#998C85",

                "predictive": "#B2A49B",
                "predictive.background": "#1B1918",
                "predictive.border": "#B2A49B",

                "unreachable": "#80756F",
                "unreachable.background": "#1A1A18",
                "unreachable.border": "#80756F",

                // Link styling
                "link_text.hover": "#C57C66",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#CCBBB1",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#E6D3C7",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#634532"
                    },

                    // Strings
                    "string": {
                        "color": "#505E49"
                    },
                    "string.escape": {
                        "color": "#FFC49F"
                    },
                    "string.regex": {
                        "color": "#FFC49F"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#8A5A7A"
                    },
                    "constant": {
                        "color": "#8A5A7A"
                    },
                    "boolean": {
                        "color": "#A8AB8B"
                    },

                    // Functions
                    "function": {
                        "color": "#BE6D55"
                    },
                    "constructor": {
                        "color": "#BE6D55"
                    },

                    // Types
                    "type": {
                        "color": "#A8AB8B"
                    },
                    "enum": {
                        "color": "#A8AB8B"
                    },

                    // Variables
                    "variable": {
                        "color": "#FFEADD"
                    },
                    "variable.special": {
                        "color": "#A8AB8B"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#BE6D55"
                    },
                    "attribute": {
                        "color": "#8A5A7A"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#FFC49F"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#E6D3C7"
                    },
                    "punctuation.bracket": {
                        "color": "#FFEADD"
                    },
                    "punctuation.delimiter": {
                        "color": "#E6D3C7"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#634532"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#BE6D55"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#505E49"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#BE6D55",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#BE6D55",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#FFC49F"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#FFEADD"
                    },
                    "preproc": {
                        "color": "#634532"
                    },
                    "primary": {
                        "color": "#FFEADD"
                    },
                    "variant": {
                        "color": "#A8AB8B"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#CCBBB1",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#B2A49B",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#BE6D55",
                        "background": "#BE6D55",
                        "selection": "#492D24"
                    },
                    {
                        "cursor": "#505E49",
                        "background": "#505E49",
                        "selection": "#232720"
                    },
                    {
                        "cursor": "#8A5A7A",
                        "background": "#8A5A7A",
                        "selection": "#372631"
                    },
                    {
                        "cursor": "#A8AB8B",
                        "background": "#A8AB8B",
                        "selection": "#424237"
                    }
                ]
            }
        }
    ]
}
