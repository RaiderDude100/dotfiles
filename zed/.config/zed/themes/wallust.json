{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#262022",
                "text": "#FDF9D6",
                "text.muted": "#CAC7AB",
                "text.placeholder": "#B1AE96",
                "text.disabled": "#989580",
                "text.accent": "#E1CADF",

                // Icon colors - match text hierarchy
                "icon": "#FDF9D6",
                "icon.muted": "#CAC7AB",
                "icon.disabled": "#989580",
                "icon.placeholder": "#B1AE96",
                "icon.accent": "#E1CADF",

                // Border colors - subtle but visible
                "border": "#656456",
                "border.variant": "#4C4B40",
                "border.focused": "#E1CADF",
                "border.selected": "#E1CADF",
                "border.transparent": "#00000000",
                "border.disabled": "#33322B",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#262022",
                "elevated_surface.background": "#3C3638",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#3A3832",
                "element.active": "#4F464D",
                "element.selected": "#423B40",
                "element.disabled": "#312B2D",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#1D1C19",
                "ghost_element.active": "#3A3832",
                "ghost_element.selected": "#282327",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#5C525A",

                // Application frame elements
                "status_bar.background": "#312B2D",
                "title_bar.background": "#262022",
                "title_bar.inactive_background": "#2D2729",
                "toolbar.background": "#262022",

                // Side panels
                "panel.background": "#262022",
                "panel.focused_border": "#E1CADF",

                // Editor panes
                "pane.focused_border": "#E1CADF",
                "pane_group.border": "#656456",

                // Tab bar and tabs
                "tab_bar.background": "#312B2D",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#262022",

                // Main editor area
                "editor.background": "#262022",
                "editor.foreground": "#FDF9D6",
                "editor.gutter.background": "#262022",
                "editor.subheader.background": "#312B2D",
                "editor.active_line.background": "#1D1C19",
                "editor.highlighted_line.background": "#3A2929",
                "editor.line_number": "#989580",
                "editor.active_line_number": "#FDF9D6",
                "editor.invisible": "#7F7D6B",
                "editor.wrap_guide": "#656456",
                "editor.active_wrap_guide": "#989580",
                "editor.indent_guide": "#656456",
                "editor.indent_guide_active": "#989580",
                "editor.document_highlight.read_background": "#483333",
                "editor.document_highlight.write_background": "#3A2A31",
                "editor.document_highlight.bracket_background": "#423B40",

                // Integrated terminal
                "terminal.background": "#262022",
                "terminal.foreground": "#FDF9D6",
                "terminal.bright_foreground": "#FDFADA",
                "terminal.dim_foreground": "#CAC7AB",
                "terminal.ansi.background": "#262022",
                "terminal.ansi.black": "#4D4648",
                "terminal.ansi.red": "#C186A3",
                "terminal.ansi.green": "#F47C4C",
                "terminal.ansi.yellow": "#FBACAB",
                "terminal.ansi.blue": "#E1CADF",
                "terminal.ansi.magenta": "#FEDCB8",
                "terminal.ansi.cyan": "#F8ED8A",
                "terminal.ansi.white": "#F3EEBC",
                "terminal.ansi.bright_black": "#AAA684",
                "terminal.ansi.bright_red": "#C186A3",
                "terminal.ansi.bright_green": "#F47C4C",
                "terminal.ansi.bright_yellow": "#FBACAB",
                "terminal.ansi.bright_blue": "#E1CADF",
                "terminal.ansi.bright_magenta": "#FEDCB8",
                "terminal.ansi.bright_cyan": "#F8ED8A",
                "terminal.ansi.bright_white": "#F3EEBC",

                // Search functionality
                "search.match_background": "#745252",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#7F7D6B",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#B1AE96",

                // Status indicators - success, warning, error, info
                "success": "#F47C4C",
                "success.background": "#46271C",
                "success.border": "#F47C4C",

                "warning": "#FBACAB",
                "warning.background": "#483333",
                "warning.border": "#FBACAB",

                "error": "#C186A3",
                "error.background": "#3A2A31",
                "error.border": "#C186A3",

                "info": "#E1CADF",
                "info.background": "#423B40",
                "info.border": "#E1CADF",

                "hint": "#CAC7AB",
                "hint.background": "#2C2A25",
                "hint.border": "#CAC7AB",

                // Git status colors
                "created": "#F47C4C",
                "created.background": "#46271C",
                "created.border": "#F47C4C",

                "modified": "#FBACAB",
                "modified.background": "#483333",
                "modified.border": "#FBACAB",

                "deleted": "#C186A3",
                "deleted.background": "#3A2A31",
                "deleted.border": "#C186A3",

                "renamed": "#E1CADF",
                "renamed.background": "#423B40",
                "renamed.border": "#E1CADF",

                "conflict": "#FEDCB8",
                "conflict.background": "#493F37",
                "conflict.border": "#FEDCB8",

                "ignored": "#B1AE96",
                "ignored.background": "#1D1C19",
                "ignored.border": "#B1AE96",

                "hidden": "#989580",
                "hidden.background": "transparent",
                "hidden.border": "#989580",

                "predictive": "#B1AE96",
                "predictive.background": "#1D1C19",
                "predictive.border": "#B1AE96",

                "unreachable": "#7F7D6B",
                "unreachable.background": "#2D2729",
                "unreachable.border": "#7F7D6B",

                // Link styling
                "link_text.hover": "#E4CFE2",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#CAC7AB",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#E4E0C1",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#C186A3"
                    },

                    // Strings
                    "string": {
                        "color": "#F47C4C"
                    },
                    "string.escape": {
                        "color": "#F8ED8A"
                    },
                    "string.regex": {
                        "color": "#F8ED8A"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#FBACAB"
                    },
                    "constant": {
                        "color": "#FBACAB"
                    },
                    "boolean": {
                        "color": "#FEDCB8"
                    },

                    // Functions
                    "function": {
                        "color": "#E1CADF"
                    },
                    "constructor": {
                        "color": "#E1CADF"
                    },

                    // Types
                    "type": {
                        "color": "#FEDCB8"
                    },
                    "enum": {
                        "color": "#FEDCB8"
                    },

                    // Variables
                    "variable": {
                        "color": "#FDF9D6"
                    },
                    "variable.special": {
                        "color": "#FEDCB8"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#E1CADF"
                    },
                    "attribute": {
                        "color": "#FBACAB"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#F8ED8A"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#E4E0C1"
                    },
                    "punctuation.bracket": {
                        "color": "#FDF9D6"
                    },
                    "punctuation.delimiter": {
                        "color": "#E4E0C1"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#C186A3"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#E1CADF"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#F47C4C"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#E1CADF",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#E1CADF",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#F8ED8A"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#FDF9D6"
                    },
                    "preproc": {
                        "color": "#C186A3"
                    },
                    "primary": {
                        "color": "#FDF9D6"
                    },
                    "variant": {
                        "color": "#FEDCB8"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#CAC7AB",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#B1AE96",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#E1CADF",
                        "background": "#E1CADF",
                        "selection": "#5C525A"
                    },
                    {
                        "cursor": "#F47C4C",
                        "background": "#F47C4C",
                        "selection": "#633726"
                    },
                    {
                        "cursor": "#FBACAB",
                        "background": "#FBACAB",
                        "selection": "#664747"
                    },
                    {
                        "cursor": "#FEDCB8",
                        "background": "#FEDCB8",
                        "selection": "#66584C"
                    }
                ]
            }
        }
    ]
}
