{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#1F1B1E",
                "text": "#FFE0BD",
                "text.muted": "#CCB397",
                "text.placeholder": "#B29D84",
                "text.disabled": "#998671",
                "text.accent": "#FD7075",

                // Icon colors - match text hierarchy
                "icon": "#FFE0BD",
                "icon.muted": "#CCB397",
                "icon.disabled": "#998671",
                "icon.placeholder": "#B29D84",
                "icon.accent": "#FD7075",

                // Border colors - subtle but visible
                "border": "#665A4C",
                "border.variant": "#4C4339",
                "border.focused": "#FD7075",
                "border.selected": "#FD7075",
                "border.transparent": "#00000000",
                "border.disabled": "#332D26",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#1F1B1E",
                "elevated_surface.background": "#353235",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#39322C",
                "element.active": "#552A2C",
                "element.selected": "#472325",
                "element.disabled": "#2A2629",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#1D1916",
                "ghost_element.active": "#39322C",
                "ghost_element.selected": "#2B1516",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#633134",

                // Application frame elements
                "status_bar.background": "#2A2629",
                "title_bar.background": "#1F1B1E",
                "title_bar.inactive_background": "#262225",
                "toolbar.background": "#1F1B1E",

                // Side panels
                "panel.background": "#1F1B1E",
                "panel.focused_border": "#FD7075",

                // Editor panes
                "pane.focused_border": "#FD7075",
                "pane_group.border": "#665A4C",

                // Tab bar and tabs
                "tab_bar.background": "#2A2629",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#1F1B1E",

                // Main editor area
                "editor.background": "#1F1B1E",
                "editor.foreground": "#FFE0BD",
                "editor.gutter.background": "#1F1B1E",
                "editor.subheader.background": "#2A2629",
                "editor.active_line.background": "#1D1916",
                "editor.highlighted_line.background": "#321F27",
                "editor.line_number": "#998671",
                "editor.active_line_number": "#FFE0BD",
                "editor.invisible": "#80705E",
                "editor.wrap_guide": "#665A4C",
                "editor.active_wrap_guide": "#998671",
                "editor.indent_guide": "#665A4C",
                "editor.indent_guide_active": "#998671",
                "editor.document_highlight.read_background": "#3F2731",
                "editor.document_highlight.write_background": "#372517",
                "editor.document_highlight.bracket_background": "#472325",

                // Integrated terminal
                "terminal.background": "#1F1B1E",
                "terminal.foreground": "#FFE0BD",
                "terminal.bright_foreground": "#FFE3C4",
                "terminal.dim_foreground": "#CCB397",
                "terminal.ansi.background": "#1F1B1E",
                "terminal.ansi.black": "#454245",
                "terminal.ansi.red": "#BB783E",
                "terminal.ansi.green": "#B86EBE",
                "terminal.ansi.yellow": "#DA82A4",
                "terminal.ansi.blue": "#FD7075",
                "terminal.ansi.magenta": "#FF885B",
                "terminal.ansi.cyan": "#FFA542",
                "terminal.ansi.white": "#F6CA98",
                "terminal.ansi.bright_black": "#AD8D6A",
                "terminal.ansi.bright_red": "#BB783E",
                "terminal.ansi.bright_green": "#B86EBE",
                "terminal.ansi.bright_yellow": "#DA82A4",
                "terminal.ansi.bright_blue": "#FD7075",
                "terminal.ansi.bright_magenta": "#FF885B",
                "terminal.ansi.bright_cyan": "#FFA542",
                "terminal.ansi.bright_white": "#F6CA98",

                // Search functionality
                "search.match_background": "#643E4E",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#80705E",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#B29D84",

                // Status indicators - success, warning, error, info
                "success": "#B86EBE",
                "success.background": "#362237",
                "success.border": "#B86EBE",

                "warning": "#DA82A4",
                "warning.background": "#3F2731",
                "warning.border": "#DA82A4",

                "error": "#BB783E",
                "error.background": "#372517",
                "error.border": "#BB783E",

                "info": "#FD7075",
                "info.background": "#472325",
                "info.border": "#FD7075",

                "hint": "#CCB397",
                "hint.background": "#2B2621",
                "hint.border": "#CCB397",

                // Git status colors
                "created": "#B86EBE",
                "created.background": "#362237",
                "created.border": "#B86EBE",

                "modified": "#DA82A4",
                "modified.background": "#3F2731",
                "modified.border": "#DA82A4",

                "deleted": "#BB783E",
                "deleted.background": "#372517",
                "deleted.border": "#BB783E",

                "renamed": "#FD7075",
                "renamed.background": "#472325",
                "renamed.border": "#FD7075",

                "conflict": "#FF885B",
                "conflict.background": "#48291F",
                "conflict.border": "#FF885B",

                "ignored": "#B29D84",
                "ignored.background": "#1D1916",
                "ignored.border": "#B29D84",

                "hidden": "#998671",
                "hidden.background": "transparent",
                "hidden.border": "#998671",

                "predictive": "#B29D84",
                "predictive.background": "#1D1916",
                "predictive.border": "#B29D84",

                "unreachable": "#80705E",
                "unreachable.background": "#262225",
                "unreachable.border": "#80705E",

                // Link styling
                "link_text.hover": "#FD7E83",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#CCB397",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#E6CAAA",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#BB783E"
                    },

                    // Strings
                    "string": {
                        "color": "#B86EBE"
                    },
                    "string.escape": {
                        "color": "#FFA542"
                    },
                    "string.regex": {
                        "color": "#FFA542"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#DA82A4"
                    },
                    "constant": {
                        "color": "#DA82A4"
                    },
                    "boolean": {
                        "color": "#FF885B"
                    },

                    // Functions
                    "function": {
                        "color": "#FD7075"
                    },
                    "constructor": {
                        "color": "#FD7075"
                    },

                    // Types
                    "type": {
                        "color": "#FF885B"
                    },
                    "enum": {
                        "color": "#FF885B"
                    },

                    // Variables
                    "variable": {
                        "color": "#FFE0BD"
                    },
                    "variable.special": {
                        "color": "#FF885B"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#FD7075"
                    },
                    "attribute": {
                        "color": "#DA82A4"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#FFA542"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#E6CAAA"
                    },
                    "punctuation.bracket": {
                        "color": "#FFE0BD"
                    },
                    "punctuation.delimiter": {
                        "color": "#E6CAAA"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#BB783E"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#FD7075"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#B86EBE"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#FD7075",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#FD7075",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#FFA542"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#FFE0BD"
                    },
                    "preproc": {
                        "color": "#BB783E"
                    },
                    "primary": {
                        "color": "#FFE0BD"
                    },
                    "variant": {
                        "color": "#FF885B"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#CCB397",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#B29D84",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#FD7075",
                        "background": "#FD7075",
                        "selection": "#633134"
                    },
                    {
                        "cursor": "#B86EBE",
                        "background": "#B86EBE",
                        "selection": "#4C304D"
                    },
                    {
                        "cursor": "#DA82A4",
                        "background": "#DA82A4",
                        "selection": "#583744"
                    },
                    {
                        "cursor": "#FF885B",
                        "background": "#FF885B",
                        "selection": "#64392B"
                    }
                ]
            }
        }
    ]
}
