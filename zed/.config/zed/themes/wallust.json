{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#211E1E",
                "text": "#F9F2EC",
                "text.muted": "#C7C2BD",
                "text.placeholder": "#AEA9A5",
                "text.disabled": "#95918E",
                "text.accent": "#C9AC82",

                // Icon colors - match text hierarchy
                "icon": "#F9F2EC",
                "icon.muted": "#C7C2BD",
                "icon.disabled": "#95918E",
                "icon.placeholder": "#AEA9A5",
                "icon.accent": "#C9AC82",

                // Border colors - subtle but visible
                "border": "#64615E",
                "border.variant": "#4B4947",
                "border.focused": "#C9AC82",
                "border.selected": "#C9AC82",
                "border.transparent": "#00000000",
                "border.disabled": "#32302F",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#211E1E",
                "elevated_surface.background": "#373535",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#383635",
                "element.active": "#463D30",
                "element.selected": "#3B3328",
                "element.disabled": "#2C2929",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#1C1B1B",
                "ghost_element.active": "#383635",
                "ghost_element.selected": "#231E18",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#524738",

                // Application frame elements
                "status_bar.background": "#2C2929",
                "title_bar.background": "#211E1E",
                "title_bar.inactive_background": "#282525",
                "toolbar.background": "#211E1E",

                // Side panels
                "panel.background": "#211E1E",
                "panel.focused_border": "#C9AC82",

                // Editor panes
                "pane.focused_border": "#C9AC82",
                "pane_group.border": "#64615E",

                // Tab bar and tabs
                "tab_bar.background": "#2C2929",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#211E1E",

                // Main editor area
                "editor.background": "#211E1E",
                "editor.foreground": "#F9F2EC",
                "editor.gutter.background": "#211E1E",
                "editor.subheader.background": "#2C2929",
                "editor.active_line.background": "#1C1B1B",
                "editor.highlighted_line.background": "#2F230B",
                "editor.line_number": "#95918E",
                "editor.active_line_number": "#F9F2EC",
                "editor.invisible": "#7D7976",
                "editor.wrap_guide": "#64615E",
                "editor.active_wrap_guide": "#95918E",
                "editor.indent_guide": "#64615E",
                "editor.indent_guide_active": "#95918E",
                "editor.document_highlight.read_background": "#3B2C0E",
                "editor.document_highlight.write_background": "#392619",
                "editor.document_highlight.bracket_background": "#3B3328",

                // Integrated terminal
                "terminal.background": "#211E1E",
                "terminal.foreground": "#F9F2EC",
                "terminal.bright_foreground": "#FAF3EE",
                "terminal.dim_foreground": "#C7C2BD",
                "terminal.ansi.background": "#211E1E",
                "terminal.ansi.black": "#484444",
                "terminal.ansi.red": "#C37944",
                "terminal.ansi.green": "#918D75",
                "terminal.ansi.yellow": "#CB9118",
                "terminal.ansi.blue": "#C9AC82",
                "terminal.ansi.magenta": "#AEB7AB",
                "terminal.ansi.cyan": "#EDDBC9",
                "terminal.ansi.white": "#EEE5DC",
                "terminal.ansi.bright_black": "#A6A09A",
                "terminal.ansi.bright_red": "#C37944",
                "terminal.ansi.bright_green": "#918D75",
                "terminal.ansi.bright_yellow": "#CB9118",
                "terminal.ansi.bright_blue": "#C9AC82",
                "terminal.ansi.bright_magenta": "#AEB7AB",
                "terminal.ansi.bright_cyan": "#EDDBC9",
                "terminal.ansi.bright_white": "#EEE5DC",

                // Search functionality
                "search.match_background": "#5E4616",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#7D7976",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#AEA9A5",

                // Status indicators - success, warning, error, info
                "success": "#918D75",
                "success.background": "#2C2B25",
                "success.border": "#918D75",

                "warning": "#CB9118",
                "warning.background": "#3B2C0E",
                "warning.border": "#CB9118",

                "error": "#C37944",
                "error.background": "#392619",
                "error.border": "#C37944",

                "info": "#C9AC82",
                "info.background": "#3B3328",
                "info.border": "#C9AC82",

                "hint": "#C7C2BD",
                "hint.background": "#2A2928",
                "hint.border": "#C7C2BD",

                // Git status colors
                "created": "#918D75",
                "created.background": "#2C2B25",
                "created.border": "#918D75",

                "modified": "#CB9118",
                "modified.background": "#3B2C0E",
                "modified.border": "#CB9118",

                "deleted": "#C37944",
                "deleted.background": "#392619",
                "deleted.border": "#C37944",

                "renamed": "#C9AC82",
                "renamed.background": "#3B3328",
                "renamed.border": "#C9AC82",

                "conflict": "#AEB7AB",
                "conflict.background": "#343532",
                "conflict.border": "#AEB7AB",

                "ignored": "#AEA9A5",
                "ignored.background": "#1C1B1B",
                "ignored.border": "#AEA9A5",

                "hidden": "#95918E",
                "hidden.background": "transparent",
                "hidden.border": "#95918E",

                "predictive": "#AEA9A5",
                "predictive.background": "#1C1B1B",
                "predictive.border": "#AEA9A5",

                "unreachable": "#7D7976",
                "unreachable.background": "#282525",
                "unreachable.border": "#7D7976",

                // Link styling
                "link_text.hover": "#CEB48F",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#C7C2BD",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#E0DAD4",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#C37944"
                    },

                    // Strings
                    "string": {
                        "color": "#918D75"
                    },
                    "string.escape": {
                        "color": "#EDDBC9"
                    },
                    "string.regex": {
                        "color": "#EDDBC9"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#CB9118"
                    },
                    "constant": {
                        "color": "#CB9118"
                    },
                    "boolean": {
                        "color": "#AEB7AB"
                    },

                    // Functions
                    "function": {
                        "color": "#C9AC82"
                    },
                    "constructor": {
                        "color": "#C9AC82"
                    },

                    // Types
                    "type": {
                        "color": "#AEB7AB"
                    },
                    "enum": {
                        "color": "#AEB7AB"
                    },

                    // Variables
                    "variable": {
                        "color": "#F9F2EC"
                    },
                    "variable.special": {
                        "color": "#AEB7AB"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#C9AC82"
                    },
                    "attribute": {
                        "color": "#CB9118"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#EDDBC9"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#E0DAD4"
                    },
                    "punctuation.bracket": {
                        "color": "#F9F2EC"
                    },
                    "punctuation.delimiter": {
                        "color": "#E0DAD4"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#C37944"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#C9AC82"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#918D75"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#C9AC82",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#C9AC82",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#EDDBC9"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#F9F2EC"
                    },
                    "preproc": {
                        "color": "#C37944"
                    },
                    "primary": {
                        "color": "#F9F2EC"
                    },
                    "variant": {
                        "color": "#AEB7AB"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#C7C2BD",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#AEA9A5",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#C9AC82",
                        "background": "#C9AC82",
                        "selection": "#524738"
                    },
                    {
                        "cursor": "#918D75",
                        "background": "#918D75",
                        "selection": "#3E3C34"
                    },
                    {
                        "cursor": "#CB9118",
                        "background": "#CB9118",
                        "selection": "#533E13"
                    },
                    {
                        "cursor": "#AEB7AB",
                        "background": "#AEB7AB",
                        "selection": "#494A46"
                    }
                ]
            }
        }
    ]
}
