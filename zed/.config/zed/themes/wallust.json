{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#1D262D",
                "text": "#90989A",
                "text.muted": "#737A7B",
                "text.placeholder": "#656A6C",
                "text.disabled": "#565B5C",
                "text.accent": "#687C85",

                // Icon colors - match text hierarchy
                "icon": "#90989A",
                "icon.muted": "#737A7B",
                "icon.disabled": "#565B5C",
                "icon.placeholder": "#656A6C",
                "icon.accent": "#687C85",

                // Border colors - subtle but visible
                "border": "#3A3D3E",
                "border.variant": "#2B2E2E",
                "border.focused": "#687C85",
                "border.selected": "#687C85",
                "border.transparent": "#00000000",
                "border.disabled": "#1D1E1F",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#1D262D",
                "elevated_surface.background": "#343C42",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#222628",
                "element.active": "#283135",
                "element.selected": "#21282C",
                "element.disabled": "#283138",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#111314",
                "ghost_element.active": "#222628",
                "ghost_element.selected": "#14181B",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#2E393E",

                // Application frame elements
                "status_bar.background": "#283138",
                "title_bar.background": "#1D262D",
                "title_bar.inactive_background": "#242D33",
                "toolbar.background": "#1D262D",

                // Side panels
                "panel.background": "#1D262D",
                "panel.focused_border": "#687C85",

                // Editor panes
                "pane.focused_border": "#687C85",
                "pane_group.border": "#3A3D3E",

                // Tab bar and tabs
                "tab_bar.background": "#283138",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#1D262D",

                // Main editor area
                "editor.background": "#1D262D",
                "editor.foreground": "#90989A",
                "editor.gutter.background": "#1D262D",
                "editor.subheader.background": "#283138",
                "editor.active_line.background": "#111314",
                "editor.highlighted_line.background": "#1E1F20",
                "editor.line_number": "#565B5C",
                "editor.active_line_number": "#90989A",
                "editor.invisible": "#484C4D",
                "editor.wrap_guide": "#3A3D3E",
                "editor.active_wrap_guide": "#565B5C",
                "editor.indent_guide": "#3A3D3E",
                "editor.indent_guide_active": "#565B5C",
                "editor.document_highlight.read_background": "#252628",
                "editor.document_highlight.write_background": "#222427",
                "editor.document_highlight.bracket_background": "#21282C",

                // Integrated terminal
                "terminal.background": "#1D262D",
                "terminal.foreground": "#90989A",
                "terminal.bright_foreground": "#9BA2A4",
                "terminal.dim_foreground": "#737A7B",
                "terminal.ansi.background": "#1D262D",
                "terminal.ansi.black": "#222C36",
                "terminal.ansi.red": "#6B6C6E",
                "terminal.ansi.green": "#5B727C",
                "terminal.ansi.yellow": "#777474",
                "terminal.ansi.blue": "#687C85",
                "terminal.ansi.magenta": "#84807E",
                "terminal.ansi.cyan": "#788790",
                "terminal.ansi.white": "#7C8589",
                "terminal.ansi.bright_black": "#38424C",
                "terminal.ansi.bright_red": "#6B6C6E",
                "terminal.ansi.bright_green": "#5B727C",
                "terminal.ansi.bright_yellow": "#777474",
                "terminal.ansi.bright_blue": "#687C85",
                "terminal.ansi.bright_magenta": "#84807E",
                "terminal.ansi.bright_cyan": "#788790",
                "terminal.ansi.bright_white": "#7C8589",

                // Search functionality
                "search.match_background": "#3B3E40",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#484C4D",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#656A6C",

                // Status indicators - success, warning, error, info
                "success": "#5B727C",
                "success.background": "#1E262A",
                "success.border": "#5B727C",

                "warning": "#777474",
                "warning.background": "#252628",
                "warning.border": "#777474",

                "error": "#6B6C6E",
                "error.background": "#222427",
                "error.border": "#6B6C6E",

                "info": "#687C85",
                "info.background": "#21282C",
                "info.border": "#687C85",

                "hint": "#737A7B",
                "hint.background": "#1A1C1E",
                "hint.border": "#737A7B",

                // Git status colors
                "created": "#5B727C",
                "created.background": "#1E262A",
                "created.border": "#5B727C",

                "modified": "#777474",
                "modified.background": "#252628",
                "modified.border": "#777474",

                "deleted": "#6B6C6E",
                "deleted.background": "#222427",
                "deleted.border": "#6B6C6E",

                "renamed": "#687C85",
                "renamed.background": "#21282C",
                "renamed.border": "#687C85",

                "conflict": "#84807E",
                "conflict.background": "#282A2B",
                "conflict.border": "#84807E",

                "ignored": "#656A6C",
                "ignored.background": "#111314",
                "ignored.border": "#656A6C",

                "hidden": "#565B5C",
                "hidden.background": "transparent",
                "hidden.border": "#565B5C",

                "predictive": "#656A6C",
                "predictive.background": "#111314",
                "predictive.border": "#656A6C",

                "unreachable": "#484C4D",
                "unreachable.background": "#242D33",
                "unreachable.border": "#484C4D",

                // Link styling
                "link_text.hover": "#778991",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#737A7B",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#82898B",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#6B6C6E"
                    },

                    // Strings
                    "string": {
                        "color": "#5B727C"
                    },
                    "string.escape": {
                        "color": "#788790"
                    },
                    "string.regex": {
                        "color": "#788790"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#777474"
                    },
                    "constant": {
                        "color": "#777474"
                    },
                    "boolean": {
                        "color": "#84807E"
                    },

                    // Functions
                    "function": {
                        "color": "#687C85"
                    },
                    "constructor": {
                        "color": "#687C85"
                    },

                    // Types
                    "type": {
                        "color": "#84807E"
                    },
                    "enum": {
                        "color": "#84807E"
                    },

                    // Variables
                    "variable": {
                        "color": "#90989A"
                    },
                    "variable.special": {
                        "color": "#84807E"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#687C85"
                    },
                    "attribute": {
                        "color": "#777474"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#788790"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#82898B"
                    },
                    "punctuation.bracket": {
                        "color": "#90989A"
                    },
                    "punctuation.delimiter": {
                        "color": "#82898B"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#6B6C6E"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#687C85"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#5B727C"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#687C85",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#687C85",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#788790"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#90989A"
                    },
                    "preproc": {
                        "color": "#6B6C6E"
                    },
                    "primary": {
                        "color": "#90989A"
                    },
                    "variant": {
                        "color": "#84807E"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#737A7B",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#656A6C",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#687C85",
                        "background": "#687C85",
                        "selection": "#2E393E"
                    },
                    {
                        "cursor": "#5B727C",
                        "background": "#5B727C",
                        "selection": "#2A353B"
                    },
                    {
                        "cursor": "#777474",
                        "background": "#777474",
                        "selection": "#343638"
                    },
                    {
                        "cursor": "#84807E",
                        "background": "#84807E",
                        "selection": "#383A3C"
                    }
                ]
            }
        }
    ]
}
