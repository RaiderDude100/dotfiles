{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#252428",
                "text": "#FDEFE4",
                "text.muted": "#CABFB6",
                "text.placeholder": "#B1A7A0",
                "text.disabled": "#988F89",
                "text.accent": "#FFB423",

                // Icon colors - match text hierarchy
                "icon": "#FDEFE4",
                "icon.muted": "#CABFB6",
                "icon.disabled": "#988F89",
                "icon.placeholder": "#B1A7A0",
                "icon.accent": "#FFB423",

                // Border colors - subtle but visible
                "border": "#65605B",
                "border.variant": "#4C4844",
                "border.focused": "#FFB423",
                "border.selected": "#FFB423",
                "border.transparent": "#00000000",
                "border.disabled": "#33302E",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#252428",
                "elevated_surface.background": "#3B3A3E",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#3A3736",
                "element.active": "#584117",
                "element.selected": "#493613",
                "element.disabled": "#302F33",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#1D1C1B",
                "ghost_element.active": "#3A3736",
                "ghost_element.selected": "#2C200B",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#664C1B",

                // Application frame elements
                "status_bar.background": "#302F33",
                "title_bar.background": "#252428",
                "title_bar.inactive_background": "#2C2B2E",
                "toolbar.background": "#252428",

                // Side panels
                "panel.background": "#252428",
                "panel.focused_border": "#FFB423",

                // Editor panes
                "pane.focused_border": "#FFB423",
                "pane_group.border": "#65605B",

                // Tab bar and tabs
                "tab_bar.background": "#302F33",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#252428",

                // Main editor area
                "editor.background": "#252428",
                "editor.foreground": "#FDEFE4",
                "editor.gutter.background": "#252428",
                "editor.subheader.background": "#302F33",
                "editor.active_line.background": "#1D1C1B",
                "editor.highlighted_line.background": "#372A36",
                "editor.line_number": "#988F89",
                "editor.active_line_number": "#FDEFE4",
                "editor.invisible": "#7F7872",
                "editor.wrap_guide": "#65605B",
                "editor.active_wrap_guide": "#988F89",
                "editor.indent_guide": "#65605B",
                "editor.indent_guide_active": "#988F89",
                "editor.document_highlight.read_background": "#453543",
                "editor.document_highlight.write_background": "#3C2C1F",
                "editor.document_highlight.bracket_background": "#493613",

                // Integrated terminal
                "terminal.background": "#252428",
                "terminal.foreground": "#FDEFE4",
                "terminal.bright_foreground": "#FDF1E7",
                "terminal.dim_foreground": "#CABFB6",
                "terminal.ansi.background": "#252428",
                "terminal.ansi.black": "#4B4A4E",
                "terminal.ansi.red": "#CA8C54",
                "terminal.ansi.green": "#F476FF",
                "terminal.ansi.yellow": "#EEAEE3",
                "terminal.ansi.blue": "#FFB423",
                "terminal.ansi.magenta": "#20E6D4",
                "terminal.ansi.cyan": "#F9D0B1",
                "terminal.ansi.white": "#F4DFD0",
                "terminal.ansi.bright_black": "#AA9C91",
                "terminal.ansi.bright_red": "#CA8C54",
                "terminal.ansi.bright_green": "#F476FF",
                "terminal.ansi.bright_yellow": "#EEAEE3",
                "terminal.ansi.bright_blue": "#FFB423",
                "terminal.ansi.bright_magenta": "#20E6D4",
                "terminal.ansi.bright_cyan": "#F9D0B1",
                "terminal.ansi.bright_white": "#F4DFD0",

                // Search functionality
                "search.match_background": "#6E546B",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#7F7872",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#B1A7A0",

                // Status indicators - success, warning, error, info
                "success": "#F476FF",
                "success.background": "#46264A",
                "success.border": "#F476FF",

                "warning": "#EEAEE3",
                "warning.background": "#453543",
                "warning.border": "#EEAEE3",

                "error": "#CA8C54",
                "error.background": "#3C2C1F",
                "error.border": "#CA8C54",

                "info": "#FFB423",
                "info.background": "#493613",
                "info.border": "#FFB423",

                "hint": "#CABFB6",
                "hint.background": "#2C2928",
                "hint.border": "#CABFB6",

                // Git status colors
                "created": "#F476FF",
                "created.background": "#46264A",
                "created.border": "#F476FF",

                "modified": "#EEAEE3",
                "modified.background": "#453543",
                "modified.border": "#EEAEE3",

                "deleted": "#CA8C54",
                "deleted.background": "#3C2C1F",
                "deleted.border": "#CA8C54",

                "renamed": "#FFB423",
                "renamed.background": "#493613",
                "renamed.border": "#FFB423",

                "conflict": "#20E6D4",
                "conflict.background": "#11423F",
                "conflict.border": "#20E6D4",

                "ignored": "#B1A7A0",
                "ignored.background": "#1D1C1B",
                "ignored.border": "#B1A7A0",

                "hidden": "#988F89",
                "hidden.background": "transparent",
                "hidden.border": "#988F89",

                "predictive": "#B1A7A0",
                "predictive.background": "#1D1C1B",
                "predictive.border": "#B1A7A0",

                "unreachable": "#7F7872",
                "unreachable.background": "#2C2B2E",
                "unreachable.border": "#7F7872",

                // Link styling
                "link_text.hover": "#FFBC39",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#CABFB6",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#E4D7CD",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#CA8C54"
                    },

                    // Strings
                    "string": {
                        "color": "#F476FF"
                    },
                    "string.escape": {
                        "color": "#F9D0B1"
                    },
                    "string.regex": {
                        "color": "#F9D0B1"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#EEAEE3"
                    },
                    "constant": {
                        "color": "#EEAEE3"
                    },
                    "boolean": {
                        "color": "#20E6D4"
                    },

                    // Functions
                    "function": {
                        "color": "#FFB423"
                    },
                    "constructor": {
                        "color": "#FFB423"
                    },

                    // Types
                    "type": {
                        "color": "#20E6D4"
                    },
                    "enum": {
                        "color": "#20E6D4"
                    },

                    // Variables
                    "variable": {
                        "color": "#FDEFE4"
                    },
                    "variable.special": {
                        "color": "#20E6D4"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#FFB423"
                    },
                    "attribute": {
                        "color": "#EEAEE3"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#F9D0B1"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#E4D7CD"
                    },
                    "punctuation.bracket": {
                        "color": "#FDEFE4"
                    },
                    "punctuation.delimiter": {
                        "color": "#E4D7CD"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#CA8C54"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#FFB423"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#F476FF"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#FFB423",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#FFB423",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#F9D0B1"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#FDEFE4"
                    },
                    "preproc": {
                        "color": "#CA8C54"
                    },
                    "primary": {
                        "color": "#FDEFE4"
                    },
                    "variant": {
                        "color": "#20E6D4"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#CABFB6",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#B1A7A0",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#FFB423",
                        "background": "#FFB423",
                        "selection": "#664C1B"
                    },
                    {
                        "cursor": "#F476FF",
                        "background": "#F476FF",
                        "selection": "#633668"
                    },
                    {
                        "cursor": "#EEAEE3",
                        "background": "#EEAEE3",
                        "selection": "#614A5E"
                    },
                    {
                        "cursor": "#20E6D4",
                        "background": "#20E6D4",
                        "selection": "#185D58"
                    }
                ]
            }
        }
    ]
}
