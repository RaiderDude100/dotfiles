{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#000016",
                "text": "#FEF4DB",
                "text.muted": "#CBC3AF",
                "text.placeholder": "#B2AB99",
                "text.disabled": "#989283",
                "text.accent": "#97E798",

                // Icon colors - match text hierarchy
                "icon": "#FEF4DB",
                "icon.muted": "#CBC3AF",
                "icon.disabled": "#989283",
                "icon.placeholder": "#B2AB99",
                "icon.accent": "#97E798",

                // Border colors - subtle but visible
                "border": "#666258",
                "border.variant": "#4C4942",
                "border.focused": "#97E798",
                "border.selected": "#97E798",
                "border.transparent": "#00000000",
                "border.disabled": "#33312C",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#000016",
                "elevated_surface.background": "#1A1A2D",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#333130",
                "element.active": "#2E4634",
                "element.selected": "#263A2C",
                "element.disabled": "#0D0D22",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#191818",
                "ghost_element.active": "#333130",
                "ghost_element.selected": "#17231A",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#35513D",

                // Application frame elements
                "status_bar.background": "#0D0D22",
                "title_bar.background": "#000016",
                "title_bar.inactive_background": "#08081D",
                "toolbar.background": "#000016",

                // Side panels
                "panel.background": "#000016",
                "panel.focused_border": "#97E798",

                // Editor panes
                "pane.focused_border": "#97E798",
                "pane_group.border": "#666258",

                // Tab bar and tabs
                "tab_bar.background": "#0D0D22",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#000016",

                // Main editor area
                "editor.background": "#000016",
                "editor.foreground": "#FEF4DB",
                "editor.gutter.background": "#000016",
                "editor.subheader.background": "#0D0D22",
                "editor.active_line.background": "#191818",
                "editor.highlighted_line.background": "#1E2A2C",
                "editor.line_number": "#989283",
                "editor.active_line_number": "#FEF4DB",
                "editor.invisible": "#7F7A6E",
                "editor.wrap_guide": "#666258",
                "editor.active_wrap_guide": "#989283",
                "editor.indent_guide": "#666258",
                "editor.indent_guide_active": "#989283",
                "editor.document_highlight.read_background": "#263537",
                "editor.document_highlight.write_background": "#143042",
                "editor.document_highlight.bracket_background": "#263A2C",

                // Integrated terminal
                "terminal.background": "#000016",
                "terminal.foreground": "#FEF4DB",
                "terminal.bright_foreground": "#FEF5DF",
                "terminal.dim_foreground": "#CBC3AF",
                "terminal.ansi.background": "#000016",
                "terminal.ansi.black": "#000016",
                "terminal.ansi.red": "#4FBFEF",
                "terminal.ansi.green": "#FBB44C",
                "terminal.ansi.yellow": "#98D2C6",
                "terminal.ansi.blue": "#97E798",
                "terminal.ansi.magenta": "#D6EA74",
                "terminal.ansi.cyan": "#FBDF99",
                "terminal.ansi.white": "#F5E7C4",
                "terminal.ansi.bright_black": "#ABA189",
                "terminal.ansi.bright_red": "#4FBFEF",
                "terminal.ansi.bright_green": "#FBB44C",
                "terminal.ansi.bright_yellow": "#98D2C6",
                "terminal.ansi.bright_blue": "#97E798",
                "terminal.ansi.bright_magenta": "#D6EA74",
                "terminal.ansi.bright_cyan": "#FBDF99",
                "terminal.ansi.bright_white": "#F5E7C4",

                // Search functionality
                "search.match_background": "#3D5458",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#7F7A6E",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#B2AB99",

                // Status indicators - success, warning, error, info
                "success": "#FBB44C",
                "success.background": "#3F2D19",
                "success.border": "#FBB44C",

                "warning": "#98D2C6",
                "warning.background": "#263537",
                "warning.border": "#98D2C6",

                "error": "#4FBFEF",
                "error.background": "#143042",
                "error.border": "#4FBFEF",

                "info": "#97E798",
                "info.background": "#263A2C",
                "info.border": "#97E798",

                "hint": "#CBC3AF",
                "hint.background": "#262524",
                "hint.border": "#CBC3AF",

                // Git status colors
                "created": "#FBB44C",
                "created.background": "#3F2D19",
                "created.border": "#FBB44C",

                "modified": "#98D2C6",
                "modified.background": "#263537",
                "modified.border": "#98D2C6",

                "deleted": "#4FBFEF",
                "deleted.background": "#143042",
                "deleted.border": "#4FBFEF",

                "renamed": "#97E798",
                "renamed.background": "#263A2C",
                "renamed.border": "#97E798",

                "conflict": "#D6EA74",
                "conflict.background": "#363B22",
                "conflict.border": "#D6EA74",

                "ignored": "#B2AB99",
                "ignored.background": "#191818",
                "ignored.border": "#B2AB99",

                "hidden": "#989283",
                "hidden.background": "transparent",
                "hidden.border": "#989283",

                "predictive": "#B2AB99",
                "predictive.background": "#191818",
                "predictive.border": "#B2AB99",

                "unreachable": "#7F7A6E",
                "unreachable.background": "#08081D",
                "unreachable.border": "#7F7A6E",

                // Link styling
                "link_text.hover": "#A1E9A2",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#CBC3AF",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#E5DCC5",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#4FBFEF"
                    },

                    // Strings
                    "string": {
                        "color": "#FBB44C"
                    },
                    "string.escape": {
                        "color": "#FBDF99"
                    },
                    "string.regex": {
                        "color": "#FBDF99"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#98D2C6"
                    },
                    "constant": {
                        "color": "#98D2C6"
                    },
                    "boolean": {
                        "color": "#D6EA74"
                    },

                    // Functions
                    "function": {
                        "color": "#97E798"
                    },
                    "constructor": {
                        "color": "#97E798"
                    },

                    // Types
                    "type": {
                        "color": "#D6EA74"
                    },
                    "enum": {
                        "color": "#D6EA74"
                    },

                    // Variables
                    "variable": {
                        "color": "#FEF4DB"
                    },
                    "variable.special": {
                        "color": "#D6EA74"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#97E798"
                    },
                    "attribute": {
                        "color": "#98D2C6"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#FBDF99"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#E5DCC5"
                    },
                    "punctuation.bracket": {
                        "color": "#FEF4DB"
                    },
                    "punctuation.delimiter": {
                        "color": "#E5DCC5"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#4FBFEF"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#97E798"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#FBB44C"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#97E798",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#97E798",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#FBDF99"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#FEF4DB"
                    },
                    "preproc": {
                        "color": "#4FBFEF"
                    },
                    "primary": {
                        "color": "#FEF4DB"
                    },
                    "variant": {
                        "color": "#D6EA74"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#CBC3AF",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#B2AB99",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#97E798",
                        "background": "#97E798",
                        "selection": "#35513D"
                    },
                    {
                        "cursor": "#FBB44C",
                        "background": "#FBB44C",
                        "selection": "#583F22"
                    },
                    {
                        "cursor": "#98D2C6",
                        "background": "#98D2C6",
                        "selection": "#354A4D"
                    },
                    {
                        "cursor": "#D6EA74",
                        "background": "#D6EA74",
                        "selection": "#4B5230"
                    }
                ]
            }
        }
    ]
}
