{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#03000F",
                "text": "#F9EFF0",
                "text.muted": "#C7BFC0",
                "text.placeholder": "#AEA7A8",
                "text.disabled": "#958F90",
                "text.accent": "#8C90AE",

                // Icon colors - match text hierarchy
                "icon": "#F9EFF0",
                "icon.muted": "#C7BFC0",
                "icon.disabled": "#958F90",
                "icon.placeholder": "#AEA7A8",
                "icon.accent": "#8C90AE",

                // Border colors - subtle but visible
                "border": "#646060",
                "border.variant": "#4B4848",
                "border.focused": "#8C90AE",
                "border.selected": "#8C90AE",
                "border.transparent": "#00000000",
                "border.disabled": "#323030",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#03000F",
                "elevated_surface.background": "#1C1A27",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#323033",
                "element.active": "#2B2B38",
                "element.selected": "#24242F",
                "element.disabled": "#100D1B",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#19181A",
                "ghost_element.active": "#323033",
                "ghost_element.selected": "#16161C",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#323242",

                // Application frame elements
                "status_bar.background": "#100D1B",
                "title_bar.background": "#03000F",
                "title_bar.inactive_background": "#0B0816",
                "toolbar.background": "#03000F",

                // Side panels
                "panel.background": "#03000F",
                "panel.focused_border": "#8C90AE",

                // Editor panes
                "pane.focused_border": "#8C90AE",
                "pane_group.border": "#646060",

                // Tab bar and tabs
                "tab_bar.background": "#100D1B",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#03000F",

                // Main editor area
                "editor.background": "#03000F",
                "editor.foreground": "#F9EFF0",
                "editor.gutter.background": "#03000F",
                "editor.subheader.background": "#100D1B",
                "editor.active_line.background": "#19181A",
                "editor.highlighted_line.background": "#1C1C26",
                "editor.line_number": "#958F90",
                "editor.active_line_number": "#F9EFF0",
                "editor.invisible": "#7D7878",
                "editor.wrap_guide": "#646060",
                "editor.active_wrap_guide": "#958F90",
                "editor.indent_guide": "#646060",
                "editor.indent_guide_active": "#958F90",
                "editor.document_highlight.read_background": "#23232F",
                "editor.document_highlight.write_background": "#191428",
                "editor.document_highlight.bracket_background": "#24242F",

                // Integrated terminal
                "terminal.background": "#03000F",
                "terminal.foreground": "#F9EFF0",
                "terminal.bright_foreground": "#FAF1F2",
                "terminal.dim_foreground": "#C7BFC0",
                "terminal.ansi.background": "#03000F",
                "terminal.ansi.black": "#1A1821",
                "terminal.ansi.red": "#60528F",
                "terminal.ansi.green": "#B46480",
                "terminal.ansi.yellow": "#898CAC",
                "terminal.ansi.blue": "#8C90AE",
                "terminal.ansi.magenta": "#9294B0",
                "terminal.ansi.cyan": "#EDD0D5",
                "terminal.ansi.white": "#EEDFE2",
                "terminal.ansi.bright_black": "#A69C9E",
                "terminal.ansi.bright_red": "#60528F",
                "terminal.ansi.bright_green": "#B46480",
                "terminal.ansi.bright_yellow": "#898CAC",
                "terminal.ansi.bright_blue": "#8C90AE",
                "terminal.ansi.bright_magenta": "#9294B0",
                "terminal.ansi.bright_cyan": "#EDD0D5",
                "terminal.ansi.bright_white": "#EEDFE2",

                // Search functionality
                "search.match_background": "#38384B",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#7D7878",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#AEA7A8",

                // Status indicators - success, warning, error, info
                "success": "#B46480",
                "success.background": "#2E1924",
                "success.border": "#B46480",

                "warning": "#898CAC",
                "warning.background": "#23232F",
                "warning.border": "#898CAC",

                "error": "#60528F",
                "error.background": "#191428",
                "error.border": "#60528F",

                "info": "#8C90AE",
                "info.background": "#24242F",
                "info.border": "#8C90AE",

                "hint": "#C7BFC0",
                "hint.background": "#262426",
                "hint.border": "#C7BFC0",

                // Git status colors
                "created": "#B46480",
                "created.background": "#2E1924",
                "created.border": "#B46480",

                "modified": "#898CAC",
                "modified.background": "#23232F",
                "modified.border": "#898CAC",

                "deleted": "#60528F",
                "deleted.background": "#191428",
                "deleted.border": "#60528F",

                "renamed": "#8C90AE",
                "renamed.background": "#24242F",
                "renamed.border": "#8C90AE",

                "conflict": "#9294B0",
                "conflict.background": "#252530",
                "conflict.border": "#9294B0",

                "ignored": "#AEA7A8",
                "ignored.background": "#19181A",
                "ignored.border": "#AEA7A8",

                "hidden": "#958F90",
                "hidden.background": "transparent",
                "hidden.border": "#958F90",

                "predictive": "#AEA7A8",
                "predictive.background": "#19181A",
                "predictive.border": "#AEA7A8",

                "unreachable": "#7D7878",
                "unreachable.background": "#0B0816",
                "unreachable.border": "#7D7878",

                // Link styling
                "link_text.hover": "#989BB6",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#C7BFC0",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#E0D7D8",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#60528F"
                    },

                    // Strings
                    "string": {
                        "color": "#B46480"
                    },
                    "string.escape": {
                        "color": "#EDD0D5"
                    },
                    "string.regex": {
                        "color": "#EDD0D5"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#898CAC"
                    },
                    "constant": {
                        "color": "#898CAC"
                    },
                    "boolean": {
                        "color": "#9294B0"
                    },

                    // Functions
                    "function": {
                        "color": "#8C90AE"
                    },
                    "constructor": {
                        "color": "#8C90AE"
                    },

                    // Types
                    "type": {
                        "color": "#9294B0"
                    },
                    "enum": {
                        "color": "#9294B0"
                    },

                    // Variables
                    "variable": {
                        "color": "#F9EFF0"
                    },
                    "variable.special": {
                        "color": "#9294B0"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#8C90AE"
                    },
                    "attribute": {
                        "color": "#898CAC"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#EDD0D5"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#E0D7D8"
                    },
                    "punctuation.bracket": {
                        "color": "#F9EFF0"
                    },
                    "punctuation.delimiter": {
                        "color": "#E0D7D8"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#60528F"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#8C90AE"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#B46480"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#8C90AE",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#8C90AE",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#EDD0D5"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#F9EFF0"
                    },
                    "preproc": {
                        "color": "#60528F"
                    },
                    "primary": {
                        "color": "#F9EFF0"
                    },
                    "variant": {
                        "color": "#9294B0"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#C7BFC0",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#AEA7A8",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#8C90AE",
                        "background": "#8C90AE",
                        "selection": "#323242"
                    },
                    {
                        "cursor": "#B46480",
                        "background": "#B46480",
                        "selection": "#402332"
                    },
                    {
                        "cursor": "#898CAC",
                        "background": "#898CAC",
                        "selection": "#313142"
                    },
                    {
                        "cursor": "#9294B0",
                        "background": "#9294B0",
                        "selection": "#343443"
                    }
                ]
            }
        }
    ]
}
