{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#5B1D4E",
                "text": "#B2B3B5",
                "text.muted": "#8E8F91",
                "text.placeholder": "#7D7D7F",
                "text.disabled": "#6B6B6D",
                "text.accent": "#4D98B7",

                // Icon colors - match text hierarchy
                "icon": "#B2B3B5",
                "icon.muted": "#8E8F91",
                "icon.disabled": "#6B6B6D",
                "icon.placeholder": "#7D7D7F",
                "icon.accent": "#4D98B7",

                // Border colors - subtle but visible
                "border": "#474848",
                "border.variant": "#353636",
                "border.focused": "#4D98B7",
                "border.selected": "#4D98B7",
                "border.transparent": "#00000000",
                "border.disabled": "#242424",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#5B1D4E",
                "elevated_surface.background": "#6B3460",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#362A34",
                "element.active": "#32364E",
                "element.selected": "#2A2D41",
                "element.disabled": "#632857",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#1B151A",
                "ghost_element.active": "#362A34",
                "ghost_element.selected": "#191B27",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#3B3F5B",

                // Application frame elements
                "status_bar.background": "#632857",
                "title_bar.background": "#5B1D4E",
                "title_bar.inactive_background": "#602453",
                "toolbar.background": "#5B1D4E",

                // Side panels
                "panel.background": "#5B1D4E",
                "panel.focused_border": "#4D98B7",

                // Editor panes
                "pane.focused_border": "#4D98B7",
                "pane_group.border": "#474848",

                // Tab bar and tabs
                "tab_bar.background": "#632857",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#5B1D4E",

                // Main editor area
                "editor.background": "#5B1D4E",
                "editor.foreground": "#B2B3B5",
                "editor.gutter.background": "#5B1D4E",
                "editor.subheader.background": "#632857",
                "editor.active_line.background": "#1B151A",
                "editor.highlighted_line.background": "#301F33",
                "editor.line_number": "#6B6B6D",
                "editor.active_line_number": "#B2B3B5",
                "editor.invisible": "#595A5A",
                "editor.wrap_guide": "#474848",
                "editor.active_wrap_guide": "#6B6B6D",
                "editor.indent_guide": "#474848",
                "editor.indent_guide_active": "#6B6B6D",
                "editor.document_highlight.read_background": "#3C2740",
                "editor.document_highlight.write_background": "#332337",
                "editor.document_highlight.bracket_background": "#2A2D41",

                // Integrated terminal
                "terminal.background": "#5B1D4E",
                "terminal.foreground": "#B2B3B5",
                "terminal.bright_foreground": "#BABBBC",
                "terminal.dim_foreground": "#8E8F91",
                "terminal.ansi.background": "#5B1D4E",
                "terminal.ansi.black": "#6B235C",
                "terminal.ansi.red": "#70708D",
                "terminal.ansi.green": "#548C99",
                "terminal.ansi.yellow": "#9580B0",
                "terminal.ansi.blue": "#4D98B7",
                "terminal.ansi.magenta": "#97979A",
                "terminal.ansi.cyan": "#8CA4B9",
                "terminal.ansi.white": "#A4A6A8",
                "terminal.ansi.bright_black": "#863C74",
                "terminal.ansi.bright_red": "#70708D",
                "terminal.ansi.bright_green": "#548C99",
                "terminal.ansi.bright_yellow": "#9580B0",
                "terminal.ansi.bright_blue": "#4D98B7",
                "terminal.ansi.bright_magenta": "#97979A",
                "terminal.ansi.bright_cyan": "#8CA4B9",
                "terminal.ansi.bright_white": "#A4A6A8",

                // Search functionality
                "search.match_background": "#603E66",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#595A5A",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#7D7D7F",

                // Status indicators - success, warning, error, info
                "success": "#548C99",
                "success.background": "#2C2A3A",
                "success.border": "#548C99",

                "warning": "#9580B0",
                "warning.background": "#3C2740",
                "warning.border": "#9580B0",

                "error": "#70708D",
                "error.background": "#332337",
                "error.border": "#70708D",

                "info": "#4D98B7",
                "info.background": "#2A2D41",
                "info.border": "#4D98B7",

                "hint": "#8E8F91",
                "hint.background": "#281F27",
                "hint.border": "#8E8F91",

                // Git status colors
                "created": "#548C99",
                "created.background": "#2C2A3A",
                "created.border": "#548C99",

                "modified": "#9580B0",
                "modified.background": "#3C2740",
                "modified.border": "#9580B0",

                "deleted": "#70708D",
                "deleted.background": "#332337",
                "deleted.border": "#70708D",

                "renamed": "#4D98B7",
                "renamed.background": "#2A2D41",
                "renamed.border": "#4D98B7",

                "conflict": "#97979A",
                "conflict.background": "#3D2D3A",
                "conflict.border": "#97979A",

                "ignored": "#7D7D7F",
                "ignored.background": "#1B151A",
                "ignored.border": "#7D7D7F",

                "hidden": "#6B6B6D",
                "hidden.background": "transparent",
                "hidden.border": "#6B6B6D",

                "predictive": "#7D7D7F",
                "predictive.background": "#1B151A",
                "predictive.border": "#7D7D7F",

                "unreachable": "#595A5A",
                "unreachable.background": "#602453",
                "unreachable.border": "#595A5A",

                // Link styling
                "link_text.hover": "#5FA2BE",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#8E8F91",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#A0A1A3",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#70708D"
                    },

                    // Strings
                    "string": {
                        "color": "#548C99"
                    },
                    "string.escape": {
                        "color": "#8CA4B9"
                    },
                    "string.regex": {
                        "color": "#8CA4B9"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#9580B0"
                    },
                    "constant": {
                        "color": "#9580B0"
                    },
                    "boolean": {
                        "color": "#97979A"
                    },

                    // Functions
                    "function": {
                        "color": "#4D98B7"
                    },
                    "constructor": {
                        "color": "#4D98B7"
                    },

                    // Types
                    "type": {
                        "color": "#97979A"
                    },
                    "enum": {
                        "color": "#97979A"
                    },

                    // Variables
                    "variable": {
                        "color": "#B2B3B5"
                    },
                    "variable.special": {
                        "color": "#97979A"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#4D98B7"
                    },
                    "attribute": {
                        "color": "#9580B0"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#8CA4B9"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#A0A1A3"
                    },
                    "punctuation.bracket": {
                        "color": "#B2B3B5"
                    },
                    "punctuation.delimiter": {
                        "color": "#A0A1A3"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#70708D"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#4D98B7"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#548C99"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#4D98B7",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#4D98B7",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#8CA4B9"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#B2B3B5"
                    },
                    "preproc": {
                        "color": "#70708D"
                    },
                    "primary": {
                        "color": "#B2B3B5"
                    },
                    "variant": {
                        "color": "#97979A"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#8E8F91",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#7D7D7F",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#4D98B7",
                        "background": "#4D98B7",
                        "selection": "#3B3F5B"
                    },
                    {
                        "cursor": "#548C99",
                        "background": "#548C99",
                        "selection": "#3E3B51"
                    },
                    {
                        "cursor": "#9580B0",
                        "background": "#9580B0",
                        "selection": "#543759"
                    },
                    {
                        "cursor": "#97979A",
                        "background": "#97979A",
                        "selection": "#553F51"
                    }
                ]
            }
        }
    ]
}
