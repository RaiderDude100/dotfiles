{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#0B1240",
                "text": "#D2D1C5",
                "text.muted": "#A8A79E",
                "text.placeholder": "#93928A",
                "text.disabled": "#7E7D76",
                "text.accent": "#99958C",

                // Icon colors - match text hierarchy
                "icon": "#D2D1C5",
                "icon.muted": "#A8A79E",
                "icon.disabled": "#7E7D76",
                "icon.placeholder": "#93928A",
                "icon.accent": "#99958C",

                // Border colors - subtle but visible
                "border": "#54544F",
                "border.variant": "#3F3F3B",
                "border.focused": "#99958C",
                "border.selected": "#99958C",
                "border.transparent": "#00000000",
                "border.disabled": "#2A2A27",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#0B1240",
                "elevated_surface.background": "#232A53",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#2C2E34",
                "element.active": "#31323D",
                "element.selected": "#292A33",
                "element.disabled": "#171E4A",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#16171A",
                "ghost_element.active": "#2C2E34",
                "ghost_element.selected": "#19191F",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#393B47",

                // Application frame elements
                "status_bar.background": "#171E4A",
                "title_bar.background": "#0B1240",
                "title_bar.inactive_background": "#121946",
                "toolbar.background": "#0B1240",

                // Side panels
                "panel.background": "#0B1240",
                "panel.focused_border": "#99958C",

                // Editor panes
                "pane.focused_border": "#99958C",
                "pane_group.border": "#54544F",

                // Tab bar and tabs
                "tab_bar.background": "#171E4A",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#0B1240",

                // Main editor area
                "editor.background": "#0B1240",
                "editor.foreground": "#D2D1C5",
                "editor.gutter.background": "#0B1240",
                "editor.subheader.background": "#171E4A",
                "editor.active_line.background": "#16171A",
                "editor.highlighted_line.background": "#191E2A",
                "editor.line_number": "#7E7D76",
                "editor.active_line_number": "#D2D1C5",
                "editor.invisible": "#696963",
                "editor.wrap_guide": "#54544F",
                "editor.active_wrap_guide": "#7E7D76",
                "editor.indent_guide": "#54544F",
                "editor.indent_guide_active": "#7E7D76",
                "editor.document_highlight.read_background": "#202634",
                "editor.document_highlight.write_background": "#1B1D28",
                "editor.document_highlight.bracket_background": "#292A33",

                // Integrated terminal
                "terminal.background": "#0B1240",
                "terminal.foreground": "#D2D1C5",
                "terminal.bright_foreground": "#D7D6CB",
                "terminal.dim_foreground": "#A8A79E",
                "terminal.ansi.background": "#0B1240",
                "terminal.ansi.black": "#0D154B",
                "terminal.ansi.red": "#60615F",
                "terminal.ansi.green": "#7F7F78",
                "terminal.ansi.yellow": "#738491",
                "terminal.ansi.blue": "#99958C",
                "terminal.ansi.magenta": "#B8B0A1",
                "terminal.ansi.cyan": "#A5BEC1",
                "terminal.ansi.white": "#D2D1C5",
                "terminal.ansi.bright_black": "#292964",
                "terminal.ansi.bright_red": "#60615F",
                "terminal.ansi.bright_green": "#7F7F78",
                "terminal.ansi.bright_yellow": "#738491",
                "terminal.ansi.bright_blue": "#99958C",
                "terminal.ansi.bright_magenta": "#B8B0A1",
                "terminal.ansi.bright_cyan": "#A5BEC1",
                "terminal.ansi.bright_white": "#D2D1C5",

                // Search functionality
                "search.match_background": "#323C53",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#696963",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#93928A",

                // Status indicators - success, warning, error, info
                "success": "#7F7F78",
                "success.background": "#22242E",
                "success.border": "#7F7F78",

                "warning": "#738491",
                "warning.background": "#202634",
                "warning.border": "#738491",

                "error": "#60615F",
                "error.background": "#1B1D28",
                "error.border": "#60615F",

                "info": "#99958C",
                "info.background": "#292A33",
                "info.border": "#99958C",

                "hint": "#A8A79E",
                "hint.background": "#212227",
                "hint.border": "#A8A79E",

                // Git status colors
                "created": "#7F7F78",
                "created.background": "#22242E",
                "created.border": "#7F7F78",

                "modified": "#738491",
                "modified.background": "#202634",
                "modified.border": "#738491",

                "deleted": "#60615F",
                "deleted.background": "#1B1D28",
                "deleted.border": "#60615F",

                "renamed": "#99958C",
                "renamed.background": "#292A33",
                "renamed.border": "#99958C",

                "conflict": "#B8B0A1",
                "conflict.background": "#313138",
                "conflict.border": "#B8B0A1",

                "ignored": "#93928A",
                "ignored.background": "#16171A",
                "ignored.border": "#93928A",

                "hidden": "#7E7D76",
                "hidden.background": "transparent",
                "hidden.border": "#7E7D76",

                "predictive": "#93928A",
                "predictive.background": "#16171A",
                "predictive.border": "#93928A",

                "unreachable": "#696963",
                "unreachable.background": "#121946",
                "unreachable.border": "#696963",

                // Link styling
                "link_text.hover": "#A3A098",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#A8A79E",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#BDBCB1",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#60615F"
                    },

                    // Strings
                    "string": {
                        "color": "#7F7F78"
                    },
                    "string.escape": {
                        "color": "#A5BEC1"
                    },
                    "string.regex": {
                        "color": "#A5BEC1"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#738491"
                    },
                    "constant": {
                        "color": "#738491"
                    },
                    "boolean": {
                        "color": "#B8B0A1"
                    },

                    // Functions
                    "function": {
                        "color": "#99958C"
                    },
                    "constructor": {
                        "color": "#99958C"
                    },

                    // Types
                    "type": {
                        "color": "#B8B0A1"
                    },
                    "enum": {
                        "color": "#B8B0A1"
                    },

                    // Variables
                    "variable": {
                        "color": "#D2D1C5"
                    },
                    "variable.special": {
                        "color": "#B8B0A1"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#99958C"
                    },
                    "attribute": {
                        "color": "#738491"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#A5BEC1"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#BDBCB1"
                    },
                    "punctuation.bracket": {
                        "color": "#D2D1C5"
                    },
                    "punctuation.delimiter": {
                        "color": "#BDBCB1"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#60615F"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#99958C"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#7F7F78"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#99958C",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#99958C",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#A5BEC1"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#D2D1C5"
                    },
                    "preproc": {
                        "color": "#60615F"
                    },
                    "primary": {
                        "color": "#D2D1C5"
                    },
                    "variant": {
                        "color": "#B8B0A1"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#A8A79E",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#93928A",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#99958C",
                        "background": "#99958C",
                        "selection": "#393B47"
                    },
                    {
                        "cursor": "#7F7F78",
                        "background": "#7F7F78",
                        "selection": "#303240"
                    },
                    {
                        "cursor": "#738491",
                        "background": "#738491",
                        "selection": "#2C3449"
                    },
                    {
                        "cursor": "#B8B0A1",
                        "background": "#B8B0A1",
                        "selection": "#45444E"
                    }
                ]
            }
        }
    ]
}
