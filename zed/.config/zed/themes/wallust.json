{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#1C1D21",
                "text": "#DFE8E1",
                "text.muted": "#B2BAB4",
                "text.placeholder": "#9CA29E",
                "text.disabled": "#868B87",
                "text.accent": "#9BA854",

                // Icon colors - match text hierarchy
                "icon": "#DFE8E1",
                "icon.muted": "#B2BAB4",
                "icon.disabled": "#868B87",
                "icon.placeholder": "#9CA29E",
                "icon.accent": "#9BA854",

                // Border colors - subtle but visible
                "border": "#595D5A",
                "border.variant": "#434644",
                "border.focused": "#9BA854",
                "border.selected": "#9BA854",
                "border.transparent": "#00000000",
                "border.disabled": "#2D2E2D",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#1C1D21",
                "elevated_surface.background": "#333437",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#323434",
                "element.active": "#373B23",
                "element.selected": "#2E311E",
                "element.disabled": "#27282C",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#191A1A",
                "ghost_element.active": "#323434",
                "ghost_element.selected": "#1C1D12",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#404529",

                // Application frame elements
                "status_bar.background": "#27282C",
                "title_bar.background": "#1C1D21",
                "title_bar.inactive_background": "#232428",
                "toolbar.background": "#1C1D21",

                // Side panels
                "panel.background": "#1C1D21",
                "panel.focused_border": "#9BA854",

                // Editor panes
                "pane.focused_border": "#9BA854",
                "pane_group.border": "#595D5A",

                // Tab bar and tabs
                "tab_bar.background": "#27282C",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#1C1D21",

                // Main editor area
                "editor.background": "#1C1D21",
                "editor.foreground": "#DFE8E1",
                "editor.gutter.background": "#1C1D21",
                "editor.subheader.background": "#27282C",
                "editor.active_line.background": "#191A1A",
                "editor.highlighted_line.background": "#222629",
                "editor.line_number": "#868B87",
                "editor.active_line_number": "#DFE8E1",
                "editor.invisible": "#707471",
                "editor.wrap_guide": "#595D5A",
                "editor.active_wrap_guide": "#868B87",
                "editor.indent_guide": "#595D5A",
                "editor.indent_guide_active": "#868B87",
                "editor.document_highlight.read_background": "#2A2F33",
                "editor.document_highlight.write_background": "#222936",
                "editor.document_highlight.bracket_background": "#2E311E",

                // Integrated terminal
                "terminal.background": "#1C1D21",
                "terminal.foreground": "#DFE8E1",
                "terminal.bright_foreground": "#E2EAE4",
                "terminal.dim_foreground": "#B2BAB4",
                "terminal.ansi.background": "#1C1D21",
                "terminal.ansi.black": "#434348",
                "terminal.ansi.red": "#6D87B7",
                "terminal.ansi.green": "#9E856E",
                "terminal.ansi.yellow": "#8EA0AA",
                "terminal.ansi.blue": "#9BA854",
                "terminal.ansi.magenta": "#BFAE89",
                "terminal.ansi.cyan": "#A3BEA9",
                "terminal.ansi.white": "#C9D6CC",
                "terminal.ansi.bright_black": "#8C968E",
                "terminal.ansi.bright_red": "#6D87B7",
                "terminal.ansi.bright_green": "#9E856E",
                "terminal.ansi.bright_yellow": "#8EA0AA",
                "terminal.ansi.bright_blue": "#9BA854",
                "terminal.ansi.bright_magenta": "#BFAE89",
                "terminal.ansi.bright_cyan": "#A3BEA9",
                "terminal.ansi.bright_white": "#C9D6CC",

                // Search functionality
                "search.match_background": "#444B52",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#707471",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#9CA29E",

                // Status indicators - success, warning, error, info
                "success": "#9E856E",
                "success.background": "#2E2824",
                "success.border": "#9E856E",

                "warning": "#8EA0AA",
                "warning.background": "#2A2F33",
                "warning.border": "#8EA0AA",

                "error": "#6D87B7",
                "error.background": "#222936",
                "error.border": "#6D87B7",

                "info": "#9BA854",
                "info.background": "#2E311E",
                "info.border": "#9BA854",

                "hint": "#B2BAB4",
                "hint.background": "#262727",
                "hint.border": "#B2BAB4",

                // Git status colors
                "created": "#9E856E",
                "created.background": "#2E2824",
                "created.border": "#9E856E",

                "modified": "#8EA0AA",
                "modified.background": "#2A2F33",
                "modified.border": "#8EA0AA",

                "deleted": "#6D87B7",
                "deleted.background": "#222936",
                "deleted.border": "#6D87B7",

                "renamed": "#9BA854",
                "renamed.background": "#2E311E",
                "renamed.border": "#9BA854",

                "conflict": "#BFAE89",
                "conflict.background": "#37332A",
                "conflict.border": "#BFAE89",

                "ignored": "#9CA29E",
                "ignored.background": "#191A1A",
                "ignored.border": "#9CA29E",

                "hidden": "#868B87",
                "hidden.background": "transparent",
                "hidden.border": "#868B87",

                "predictive": "#9CA29E",
                "predictive.background": "#191A1A",
                "predictive.border": "#9CA29E",

                "unreachable": "#707471",
                "unreachable.background": "#232428",
                "unreachable.border": "#707471",

                // Link styling
                "link_text.hover": "#A5B165",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#B2BAB4",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#C9D1CB",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#6D87B7"
                    },

                    // Strings
                    "string": {
                        "color": "#9E856E"
                    },
                    "string.escape": {
                        "color": "#A3BEA9"
                    },
                    "string.regex": {
                        "color": "#A3BEA9"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#8EA0AA"
                    },
                    "constant": {
                        "color": "#8EA0AA"
                    },
                    "boolean": {
                        "color": "#BFAE89"
                    },

                    // Functions
                    "function": {
                        "color": "#9BA854"
                    },
                    "constructor": {
                        "color": "#9BA854"
                    },

                    // Types
                    "type": {
                        "color": "#BFAE89"
                    },
                    "enum": {
                        "color": "#BFAE89"
                    },

                    // Variables
                    "variable": {
                        "color": "#DFE8E1"
                    },
                    "variable.special": {
                        "color": "#BFAE89"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#9BA854"
                    },
                    "attribute": {
                        "color": "#8EA0AA"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#A3BEA9"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#C9D1CB"
                    },
                    "punctuation.bracket": {
                        "color": "#DFE8E1"
                    },
                    "punctuation.delimiter": {
                        "color": "#C9D1CB"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#6D87B7"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#9BA854"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#9E856E"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#9BA854",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#9BA854",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#A3BEA9"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#DFE8E1"
                    },
                    "preproc": {
                        "color": "#6D87B7"
                    },
                    "primary": {
                        "color": "#DFE8E1"
                    },
                    "variant": {
                        "color": "#BFAE89"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#B2BAB4",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#9CA29E",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#9BA854",
                        "background": "#9BA854",
                        "selection": "#404529"
                    },
                    {
                        "cursor": "#9E856E",
                        "background": "#9E856E",
                        "selection": "#413932"
                    },
                    {
                        "cursor": "#8EA0AA",
                        "background": "#8EA0AA",
                        "selection": "#3C4247"
                    },
                    {
                        "cursor": "#BFAE89",
                        "background": "#BFAE89",
                        "selection": "#4D473C"
                    }
                ]
            }
        }
    ]
}
