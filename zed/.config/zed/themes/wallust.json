{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#080D0E",
                "text": "#A8C5D0",
                "text.muted": "#869EA6",
                "text.placeholder": "#768A92",
                "text.disabled": "#65767D",
                "text.accent": "#887966",

                // Icon colors - match text hierarchy
                "icon": "#A8C5D0",
                "icon.muted": "#869EA6",
                "icon.disabled": "#65767D",
                "icon.placeholder": "#768A92",
                "icon.accent": "#887966",

                // Border colors - subtle but visible
                "border": "#434F53",
                "border.variant": "#323B3E",
                "border.focused": "#887966",
                "border.selected": "#887966",
                "border.transparent": "#00000000",
                "border.disabled": "#22272A",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#080D0E",
                "elevated_surface.background": "#212526",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#232A2C",
                "element.active": "#2B2823",
                "element.selected": "#24221D",
                "element.disabled": "#14191A",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#121516",
                "ghost_element.active": "#232A2C",
                "ghost_element.selected": "#161411",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#322F29",

                // Application frame elements
                "status_bar.background": "#14191A",
                "title_bar.background": "#080D0E",
                "title_bar.inactive_background": "#0F1415",
                "toolbar.background": "#080D0E",

                // Side panels
                "panel.background": "#080D0E",
                "panel.focused_border": "#887966",

                // Editor panes
                "pane.focused_border": "#887966",
                "pane_group.border": "#434F53",

                // Tab bar and tabs
                "tab_bar.background": "#14191A",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#080D0E",

                // Main editor area
                "editor.background": "#080D0E",
                "editor.foreground": "#A8C5D0",
                "editor.gutter.background": "#080D0E",
                "editor.subheader.background": "#14191A",
                "editor.active_line.background": "#121516",
                "editor.highlighted_line.background": "#191C1A",
                "editor.line_number": "#65767D",
                "editor.active_line_number": "#A8C5D0",
                "editor.invisible": "#546368",
                "editor.wrap_guide": "#434F53",
                "editor.active_wrap_guide": "#65767D",
                "editor.indent_guide": "#434F53",
                "editor.indent_guide_active": "#65767D",
                "editor.document_highlight.read_background": "#1F2320",
                "editor.document_highlight.write_background": "#161D20",
                "editor.document_highlight.bracket_background": "#24221D",

                // Integrated terminal
                "terminal.background": "#080D0E",
                "terminal.foreground": "#A8C5D0",
                "terminal.bright_foreground": "#B1CBD5",
                "terminal.dim_foreground": "#869EA6",
                "terminal.ansi.background": "#080D0E",
                "terminal.ansi.black": "#0A0F10",
                "terminal.ansi.red": "#516472",
                "terminal.ansi.green": "#5E7480",
                "terminal.ansi.yellow": "#737E72",
                "terminal.ansi.blue": "#887966",
                "terminal.ansi.magenta": "#768A96",
                "terminal.ansi.cyan": "#99A6A6",
                "terminal.ansi.white": "#A8C5D0",
                "terminal.ansi.bright_black": "#212425",
                "terminal.ansi.bright_red": "#516472",
                "terminal.ansi.bright_green": "#5E7480",
                "terminal.ansi.bright_yellow": "#737E72",
                "terminal.ansi.bright_blue": "#887966",
                "terminal.ansi.bright_magenta": "#768A96",
                "terminal.ansi.bright_cyan": "#99A6A6",
                "terminal.ansi.bright_white": "#A8C5D0",

                // Search functionality
                "search.match_background": "#323833",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#546368",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#768A92",

                // Status indicators - success, warning, error, info
                "success": "#5E7480",
                "success.background": "#1A2024",
                "success.border": "#5E7480",

                "warning": "#737E72",
                "warning.background": "#1F2320",
                "warning.border": "#737E72",

                "error": "#516472",
                "error.background": "#161D20",
                "error.border": "#516472",

                "info": "#887966",
                "info.background": "#24221D",
                "info.border": "#887966",

                "hint": "#869EA6",
                "hint.background": "#1A2021",
                "hint.border": "#869EA6",

                // Git status colors
                "created": "#5E7480",
                "created.background": "#1A2024",
                "created.border": "#5E7480",

                "modified": "#737E72",
                "modified.background": "#1F2320",
                "modified.border": "#737E72",

                "deleted": "#516472",
                "deleted.background": "#161D20",
                "deleted.border": "#516472",

                "renamed": "#887966",
                "renamed.background": "#24221D",
                "renamed.border": "#887966",

                "conflict": "#768A96",
                "conflict.background": "#202629",
                "conflict.border": "#768A96",

                "ignored": "#768A92",
                "ignored.background": "#121516",
                "ignored.border": "#768A92",

                "hidden": "#65767D",
                "hidden.background": "transparent",
                "hidden.border": "#65767D",

                "predictive": "#768A92",
                "predictive.background": "#121516",
                "predictive.border": "#768A92",

                "unreachable": "#546368",
                "unreachable.background": "#0F1415",
                "unreachable.border": "#546368",

                // Link styling
                "link_text.hover": "#948675",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#869EA6",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#97B1BB",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#516472"
                    },

                    // Strings
                    "string": {
                        "color": "#5E7480"
                    },
                    "string.escape": {
                        "color": "#99A6A6"
                    },
                    "string.regex": {
                        "color": "#99A6A6"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#737E72"
                    },
                    "constant": {
                        "color": "#737E72"
                    },
                    "boolean": {
                        "color": "#768A96"
                    },

                    // Functions
                    "function": {
                        "color": "#887966"
                    },
                    "constructor": {
                        "color": "#887966"
                    },

                    // Types
                    "type": {
                        "color": "#768A96"
                    },
                    "enum": {
                        "color": "#768A96"
                    },

                    // Variables
                    "variable": {
                        "color": "#A8C5D0"
                    },
                    "variable.special": {
                        "color": "#768A96"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#887966"
                    },
                    "attribute": {
                        "color": "#737E72"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#99A6A6"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#97B1BB"
                    },
                    "punctuation.bracket": {
                        "color": "#A8C5D0"
                    },
                    "punctuation.delimiter": {
                        "color": "#97B1BB"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#516472"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#887966"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#5E7480"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#887966",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#887966",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#99A6A6"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#A8C5D0"
                    },
                    "preproc": {
                        "color": "#516472"
                    },
                    "primary": {
                        "color": "#A8C5D0"
                    },
                    "variant": {
                        "color": "#768A96"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#869EA6",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#768A92",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#887966",
                        "background": "#887966",
                        "selection": "#322F29"
                    },
                    {
                        "cursor": "#5E7480",
                        "background": "#5E7480",
                        "selection": "#242D32"
                    },
                    {
                        "cursor": "#737E72",
                        "background": "#737E72",
                        "selection": "#2B312D"
                    },
                    {
                        "cursor": "#768A96",
                        "background": "#768A96",
                        "selection": "#2C3539"
                    }
                ]
            }
        }
    ]
}
