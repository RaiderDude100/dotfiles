{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#151313",
                "text": "#F6F1EA",
                "text.muted": "#C5C1BB",
                "text.placeholder": "#ACA9A4",
                "text.disabled": "#94918C",
                "text.accent": "#A37953",

                // Icon colors - match text hierarchy
                "icon": "#F6F1EA",
                "icon.muted": "#C5C1BB",
                "icon.disabled": "#94918C",
                "icon.placeholder": "#ACA9A4",
                "icon.accent": "#A37953",

                // Border colors - subtle but visible
                "border": "#62605E",
                "border.variant": "#4A4846",
                "border.focused": "#A37953",
                "border.selected": "#A37953",
                "border.transparent": "#00000000",
                "border.disabled": "#31302F",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#151313",
                "elevated_surface.background": "#2C2B2B",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#363433",
                "element.active": "#372A1F",
                "element.selected": "#2E231A",
                "element.disabled": "#211F1F",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#1B1A19",
                "ghost_element.active": "#363433",
                "ghost_element.selected": "#1C150F",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#403124",

                // Application frame elements
                "status_bar.background": "#211F1F",
                "title_bar.background": "#151313",
                "title_bar.inactive_background": "#1C1A1A",
                "toolbar.background": "#151313",

                // Side panels
                "panel.background": "#151313",
                "panel.focused_border": "#A37953",

                // Editor panes
                "pane.focused_border": "#A37953",
                "pane_group.border": "#62605E",

                // Tab bar and tabs
                "tab_bar.background": "#211F1F",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#151313",

                // Main editor area
                "editor.background": "#151313",
                "editor.foreground": "#F6F1EA",
                "editor.gutter.background": "#151313",
                "editor.subheader.background": "#211F1F",
                "editor.active_line.background": "#1B1A19",
                "editor.highlighted_line.background": "#221C16",
                "editor.line_number": "#94918C",
                "editor.active_line_number": "#F6F1EA",
                "editor.invisible": "#7B7975",
                "editor.wrap_guide": "#62605E",
                "editor.active_wrap_guide": "#94918C",
                "editor.indent_guide": "#62605E",
                "editor.indent_guide_active": "#94918C",
                "editor.document_highlight.read_background": "#2B221B",
                "editor.document_highlight.write_background": "#1E1B19",
                "editor.document_highlight.bracket_background": "#2E231A",

                // Integrated terminal
                "terminal.background": "#151313",
                "terminal.foreground": "#F6F1EA",
                "terminal.bright_foreground": "#F7F2EC",
                "terminal.dim_foreground": "#C5C1BB",
                "terminal.ansi.background": "#151313",
                "terminal.ansi.black": "#191616",
                "terminal.ansi.red": "#63594F",
                "terminal.ansi.green": "#7B6E56",
                "terminal.ansi.yellow": "#977759",
                "terminal.ansi.blue": "#A37953",
                "terminal.ansi.magenta": "#8F847B",
                "terminal.ansi.cyan": "#D69B31",
                "terminal.ansi.white": "#F6F1EA",
                "terminal.ansi.bright_black": "#2D2B2A",
                "terminal.ansi.bright_red": "#63594F",
                "terminal.ansi.bright_green": "#7B6E56",
                "terminal.ansi.bright_yellow": "#977759",
                "terminal.ansi.bright_blue": "#A37953",
                "terminal.ansi.bright_magenta": "#8F847B",
                "terminal.ansi.bright_cyan": "#D69B31",
                "terminal.ansi.bright_white": "#F6F1EA",

                // Search functionality
                "search.match_background": "#45372B",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#7B7975",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#ACA9A4",

                // Status indicators - success, warning, error, info
                "success": "#7B6E56",
                "success.background": "#24201A",
                "success.border": "#7B6E56",

                "warning": "#977759",
                "warning.background": "#2B221B",
                "warning.border": "#977759",

                "error": "#63594F",
                "error.background": "#1E1B19",
                "error.border": "#63594F",

                "info": "#A37953",
                "info.background": "#2E231A",
                "info.border": "#A37953",

                "hint": "#C5C1BB",
                "hint.background": "#282726",
                "hint.border": "#C5C1BB",

                // Git status colors
                "created": "#7B6E56",
                "created.background": "#24201A",
                "created.border": "#7B6E56",

                "modified": "#977759",
                "modified.background": "#2B221B",
                "modified.border": "#977759",

                "deleted": "#63594F",
                "deleted.background": "#1E1B19",
                "deleted.border": "#63594F",

                "renamed": "#A37953",
                "renamed.background": "#2E231A",
                "renamed.border": "#A37953",

                "conflict": "#8F847B",
                "conflict.background": "#292624",
                "conflict.border": "#8F847B",

                "ignored": "#ACA9A4",
                "ignored.background": "#1B1A19",
                "ignored.border": "#ACA9A4",

                "hidden": "#94918C",
                "hidden.background": "transparent",
                "hidden.border": "#94918C",

                "predictive": "#ACA9A4",
                "predictive.background": "#1B1A19",
                "predictive.border": "#ACA9A4",

                "unreachable": "#7B7975",
                "unreachable.background": "#1C1A1A",
                "unreachable.border": "#7B7975",

                // Link styling
                "link_text.hover": "#AC8664",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#C5C1BB",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#DDD9D3",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#63594F"
                    },

                    // Strings
                    "string": {
                        "color": "#7B6E56"
                    },
                    "string.escape": {
                        "color": "#D69B31"
                    },
                    "string.regex": {
                        "color": "#D69B31"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#977759"
                    },
                    "constant": {
                        "color": "#977759"
                    },
                    "boolean": {
                        "color": "#8F847B"
                    },

                    // Functions
                    "function": {
                        "color": "#A37953"
                    },
                    "constructor": {
                        "color": "#A37953"
                    },

                    // Types
                    "type": {
                        "color": "#8F847B"
                    },
                    "enum": {
                        "color": "#8F847B"
                    },

                    // Variables
                    "variable": {
                        "color": "#F6F1EA"
                    },
                    "variable.special": {
                        "color": "#8F847B"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#A37953"
                    },
                    "attribute": {
                        "color": "#977759"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#D69B31"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#DDD9D3"
                    },
                    "punctuation.bracket": {
                        "color": "#F6F1EA"
                    },
                    "punctuation.delimiter": {
                        "color": "#DDD9D3"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#63594F"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#A37953"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#7B6E56"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#A37953",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#A37953",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#D69B31"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#F6F1EA"
                    },
                    "preproc": {
                        "color": "#63594F"
                    },
                    "primary": {
                        "color": "#F6F1EA"
                    },
                    "variant": {
                        "color": "#8F847B"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#C5C1BB",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#ACA9A4",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#A37953",
                        "background": "#A37953",
                        "selection": "#403124"
                    },
                    {
                        "cursor": "#7B6E56",
                        "background": "#7B6E56",
                        "selection": "#322D24"
                    },
                    {
                        "cursor": "#977759",
                        "background": "#977759",
                        "selection": "#3C3026"
                    },
                    {
                        "cursor": "#8F847B",
                        "background": "#8F847B",
                        "selection": "#393532"
                    }
                ]
            }
        }
    ]
}
