{
    "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
    "author": "Jan Reinsch <jan@coded-aesthetics.com>",
    "name": "Wallust",
    "themes": [
        {
            "name": "Wallust",
            "appearance": "dark",
            "style": {
                // Basic text and background colors
                "background": "#060607",
                "text": "#F2F6F5",
                "text.muted": "#C2C5C4",
                "text.placeholder": "#A9ACAC",
                "text.disabled": "#919493",
                "text.accent": "#0178D8",

                // Icon colors - match text hierarchy
                "icon": "#F2F6F5",
                "icon.muted": "#C2C5C4",
                "icon.disabled": "#919493",
                "icon.placeholder": "#A9ACAC",
                "icon.accent": "#0178D8",

                // Border colors - subtle but visible
                "border": "#616262",
                "border.variant": "#494A4A",
                "border.focused": "#0178D8",
                "border.selected": "#0178D8",
                "border.transparent": "#00000000",
                "border.disabled": "#303131",

                // Surface backgrounds - slightly elevated from main background
                "surface.background": "#060607",
                "elevated_surface.background": "#1F1F20",

                // Interactive element states
                "element.background": "transparent",
                "element.hover": "#323232",
                "element.active": "#022643",
                "element.selected": "#022038",
                "element.disabled": "#121213",

                // Ghost elements - more subtle interactions
                "ghost_element.background": "transparent",
                "ghost_element.hover": "#191919",
                "ghost_element.active": "#323232",
                "ghost_element.selected": "#011322",
                "ghost_element.disabled": "transparent",

                // Drag and drop target
                "drop_target.background": "#032C4E",

                // Application frame elements
                "status_bar.background": "#121213",
                "title_bar.background": "#060607",
                "title_bar.inactive_background": "#0D0D0E",
                "toolbar.background": "#060607",

                // Side panels
                "panel.background": "#060607",
                "panel.focused_border": "#0178D8",

                // Editor panes
                "pane.focused_border": "#0178D8",
                "pane_group.border": "#616262",

                // Tab bar and tabs
                "tab_bar.background": "#121213",
                "tab.inactive_background": "transparent",
                "tab.active_background": "#060607",

                // Main editor area
                "editor.background": "#060607",
                "editor.foreground": "#F2F6F5",
                "editor.gutter.background": "#060607",
                "editor.subheader.background": "#121213",
                "editor.active_line.background": "#191919",
                "editor.highlighted_line.background": "#191A1B",
                "editor.line_number": "#919493",
                "editor.active_line_number": "#F2F6F5",
                "editor.invisible": "#797B7B",
                "editor.wrap_guide": "#616262",
                "editor.active_wrap_guide": "#919493",
                "editor.indent_guide": "#616262",
                "editor.indent_guide_active": "#919493",
                "editor.document_highlight.read_background": "#202122",
                "editor.document_highlight.write_background": "#10141A",
                "editor.document_highlight.bracket_background": "#022038",

                // Integrated terminal
                "terminal.background": "#060607",
                "terminal.foreground": "#F2F6F5",
                "terminal.bright_foreground": "#F3F7F6",
                "terminal.dim_foreground": "#C2C5C4",
                "terminal.ansi.background": "#060607",
                "terminal.ansi.black": "#070609",
                "terminal.ansi.red": "#3A4B5F",
                "terminal.ansi.green": "#3A70A0",
                "terminal.ansi.yellow": "#777D80",
                "terminal.ansi.blue": "#0178D8",
                "terminal.ansi.magenta": "#B6871B",
                "terminal.ansi.cyan": "#64CBFA",
                "terminal.ansi.white": "#F2F6F5",
                "terminal.ansi.bright_black": "#1F1F20",
                "terminal.ansi.bright_red": "#3A4B5F",
                "terminal.ansi.bright_green": "#3A70A0",
                "terminal.ansi.bright_yellow": "#777D80",
                "terminal.ansi.bright_blue": "#0178D8",
                "terminal.ansi.bright_magenta": "#B6871B",
                "terminal.ansi.bright_cyan": "#64CBFA",
                "terminal.ansi.bright_white": "#F2F6F5",

                // Search functionality
                "search.match_background": "#323536",

                // Scrollbar elements
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "transparent",
                "scrollbar.thumb.background": "#797B7B",
                "scrollbar.thumb.border": "transparent",
                "scrollbar.thumb.hover_background": "#A9ACAC",

                // Status indicators - success, warning, error, info
                "success": "#3A70A0",
                "success.background": "#101E2A",
                "success.border": "#3A70A0",

                "warning": "#777D80",
                "warning.background": "#202122",
                "warning.border": "#777D80",

                "error": "#3A4B5F",
                "error.background": "#10141A",
                "error.border": "#3A4B5F",

                "info": "#0178D8",
                "info.background": "#022038",
                "info.border": "#0178D8",

                "hint": "#C2C5C4",
                "hint.background": "#252626",
                "hint.border": "#C2C5C4",

                // Git status colors
                "created": "#3A70A0",
                "created.background": "#101E2A",
                "created.border": "#3A70A0",

                "modified": "#777D80",
                "modified.background": "#202122",
                "modified.border": "#777D80",

                "deleted": "#3A4B5F",
                "deleted.background": "#10141A",
                "deleted.border": "#3A4B5F",

                "renamed": "#0178D8",
                "renamed.background": "#022038",
                "renamed.border": "#0178D8",

                "conflict": "#B6871B",
                "conflict.background": "#2F2308",
                "conflict.border": "#B6871B",

                "ignored": "#A9ACAC",
                "ignored.background": "#191919",
                "ignored.border": "#A9ACAC",

                "hidden": "#919493",
                "hidden.background": "transparent",
                "hidden.border": "#919493",

                "predictive": "#A9ACAC",
                "predictive.background": "#191919",
                "predictive.border": "#A9ACAC",

                "unreachable": "#797B7B",
                "unreachable.background": "#0D0D0E",
                "unreachable.border": "#797B7B",

                // Link styling
                "link_text.hover": "#1A86DC",

                // Syntax highlighting - follows standard color assignments
                "syntax": {
                    // Comments - muted but readable
                    "comment": {
                        "color": "#C2C5C4",
                        "font_style": "italic"
                    },
                    "comment.doc": {
                        "color": "#DADDDD",
                        "font_style": "italic"
                    },

                    // Keywords
                    "keyword": {
                        "color": "#3A4B5F"
                    },

                    // Strings
                    "string": {
                        "color": "#3A70A0"
                    },
                    "string.escape": {
                        "color": "#64CBFA"
                    },
                    "string.regex": {
                        "color": "#64CBFA"
                    },

                    // Numbers and constants
                    "number": {
                        "color": "#777D80"
                    },
                    "constant": {
                        "color": "#777D80"
                    },
                    "boolean": {
                        "color": "#B6871B"
                    },

                    // Functions
                    "function": {
                        "color": "#0178D8"
                    },
                    "constructor": {
                        "color": "#0178D8"
                    },

                    // Types
                    "type": {
                        "color": "#B6871B"
                    },
                    "enum": {
                        "color": "#B6871B"
                    },

                    // Variables
                    "variable": {
                        "color": "#F2F6F5"
                    },
                    "variable.special": {
                        "color": "#B6871B"
                    },

                    // Properties and attributes
                    "property": {
                        "color": "#0178D8"
                    },
                    "attribute": {
                        "color": "#777D80"
                    },

                    // Operators - typically cyan (color6)
                    "operator": {
                        "color": "#64CBFA"
                    },

                    // Punctuation - subtle but visible
                    "punctuation": {
                        "color": "#DADDDD"
                    },
                    "punctuation.bracket": {
                        "color": "#F2F6F5"
                    },
                    "punctuation.delimiter": {
                        "color": "#DADDDD"
                    },

                    // Tags (HTML/XML)
                    "tag": {
                        "color": "#3A4B5F"
                    },

                    // Labels and identifiers
                    "label": {
                        "color": "#0178D8"
                    },

                    // Text literals
                    "text.literal": {
                        "color": "#3A70A0"
                    },

                    // Titles and headings
                    "title": {
                        "color": "#0178D8",
                        "font_weight": 700
                    },

                    // Links in markdown/docs
                    "link_text": {
                        "color": "#0178D8",
                        "font_style": "italic"
                    },
                    "link_uri": {
                        "color": "#64CBFA"
                    },

                    // Text emphasis
                    "emphasis": {
                        "font_style": "italic"
                    },
                    "emphasis.strong": {
                        "font_weight": 700
                    },

                    // Special syntax elements
                    "embedded": {
                        "color": "#F2F6F5"
                    },
                    "preproc": {
                        "color": "#3A4B5F"
                    },
                    "primary": {
                        "color": "#F2F6F5"
                    },
                    "variant": {
                        "color": "#B6871B"
                    },

                    // Editor hints and diagnostics
                    "hint": {
                        "color": "#C2C5C4",
                        "font_weight": 700
                    },
                    "predictive": {
                        "color": "#A9ACAC",
                        "font_style": "italic"
                    }
                },

                // Collaborative editing - different users get different colors
                "players": [
                    {
                        "cursor": "#0178D8",
                        "background": "#0178D8",
                        "selection": "#032C4E"
                    },
                    {
                        "cursor": "#3A70A0",
                        "background": "#3A70A0",
                        "selection": "#16293B"
                    },
                    {
                        "cursor": "#777D80",
                        "background": "#777D80",
                        "selection": "#2C2E30"
                    },
                    {
                        "cursor": "#B6871B",
                        "background": "#B6871B",
                        "selection": "#42310C"
                    }
                ]
            }
        }
    ]
}
